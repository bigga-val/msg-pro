{% extends 'base.html.twig' %}

{% block title %}Liste des Contacts{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="card">
        <div class="card-header bg-gradient-dark d-flex justify-content-between align-items-center">
            <h3 class="card-title mb-0">Liste des Contacts</h3>
            <a href="{{ path('app_contact_new') }}" class="btn btn-success btn-sm">
                <i class="fas fa-plus"></i> Nouveau contact
            </a>
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover" id="example1">
                <thead class="thead-dark">
                <tr>
                    <th>#</th>
                    <th>Téléphone</th>
                    <th>Nom</th>
                    <th>Postnom</th>
                    <th>Adresse</th>
                    <th>Fonction</th>
                    {% if is_granted('ROLE_ADMIN') %}
                    <th>Utilisateur</th>
                    {% endif %}
                    <th>Organisation</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% if is_granted('ROLE_ADMIN') %}
                    {% set counter = 0 %}
                    {% for contact in contacts %}
                        {% set counter = counter + 1 %}
                        <tr>
                            <td>{{ counter }}</td>
                            <td>{{ contact.telephone }}</td>
                            <td>{{ contact.nom }}</td>
                            <td>{{ contact.postnom }}</td>
                            <td>{{ contact.adresse }}</td>
                            <td>{{ contact.fonction }}</td>
                            <td>{{ contact.user is not null ? contact.user.username : '' }}</td>
                            <td>{{ contact.groupe is not null and contact.groupe.organisation is not null ? contact.groupe.organisation.designation : '' }}</td>
                            <td>
                                <a href="{{ path('app_contact_show', {'id': contact.id}) }}" class="btn btn-sm btn-default">Détails</a>
                                <a href="{{ path('app_contact_edit', {'id': contact.id}) }}" class="btn btn-sm btn-primary">Modifier</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="9" class="text-center text-muted">Aucun contact trouvé</td>
                        </tr>
                    {% endfor %}
                {% else %}
                    {% set counter = 0 %}
                    {% for contact in contacts %}
                        {% set counter = counter + 1 %}
                        <tr>
                            <td>{{ counter }}</td>
                            <td>{{ contact.telephone }}</td>
                            <td>{{ contact.nom }}</td>
                            <td>{{ contact.postnom }}</td>
                            <td>{{ contact.adresse }}</td>
                            <td>{{ contact.fonction }}</td>
                            <td>{{ contact.organisation }}</td>
                            <td>
                                <a href="{{ path('app_contact_show', {'id': contact.id}) }}" class="btn btn-sm btn-default">Détails</a>
                                <a href="{{ path('app_contact_edit', {'id': contact.id}) }}" class="btn btn-sm btn-primary">Modifier</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="8" class="text-center text-muted">Aucun contact trouvé</td>
                        </tr>
                    {% endfor %}
                {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="{{ asset("plugins/jquery/jquery.js") }}"></script>
<script>
    $(function () {
        $("#example1").DataTable({
            "responsive": true, "lengthChange": false, "autoWidth": false,
            "buttons": ["csv", "excel", "pdf", "print", "colvis"]
        }).buttons().container().appendTo('#example1_wrapper .col-md-6:eq(0)');
    })
</script>
{% endblock %}
