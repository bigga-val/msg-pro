{% extends 'base.html.twig' %}

{% block title %}Liste des Contacts{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/contact.css') }}">
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="card">
        <div class="card-header contact-card-header">
            <h3 class="card-title mb-0"><i class="fas fa-address-book me-2"></i>Liste des Contacts</h3>
            <a href="{{ path('app_contact_new') }}" class="btn btn-primary btn-sm">
                <i class="fas fa-plus me-1"></i> Nouveau contact
            </a>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover contact-table mb-0" id="example1">
                <thead class="contact-thead">
                    <tr>
                        <th>#</th>
                        <th>Téléphone</th>
                        <th>Nom</th>
                        <th>Postnom</th>
                        <th>Adresse</th>
                        <th>Fonction</th>
                        {% if is_granted('ROLE_ADMIN') %}
                            <th>Utilisateur</th>
                        {% endif %}
                        <th>Groupe(s)</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% set counter = 0 %}
                    {% for contact in contacts %}
                        {% set counter = counter + 1 %}
                        <tr>
                            <td>{{ counter }}</td>
                            <td>{{ contact.telephone }}</td>
                            <td>{{ contact.nom }}</td>
                            <td>{{ contact.postnom }}</td>
                            <td>{{ contact.adresse }}</td>
                            <td>{{ contact.fonction }}</td>
                            {% if is_granted('ROLE_ADMIN') %}
                                <td>{{ contact.user is not null ? contact.user.username : '—' }}</td>
                            {% endif %}
                            <td>
                                {% for cg in contact.contactGroupes %}
                                    {% if cg.groupe is not null %}
                                        <span class="badge badge-info">{{ cg.groupe.designation }}</span>
                                    {% endif %}
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endfor %}
                            </td>
                            <td class="col-actions">
                                <a href="{{ path('app_contact_show', {'id': contact.id}) }}" class="btn btn-sm btn-default">Détails</a>
                                <a href="{{ path('app_contact_edit', {'id': contact.id}) }}" class="btn btn-sm btn-primary">Modifier</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="{{ is_granted('ROLE_ADMIN') ? 9 : 8 }}" class="text-center text-muted py-4">
                                <i class="fas fa-inbox fa-2x d-block mb-2" style="color:#cbd5e1;"></i>
                                Aucun contact trouvé
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    $(function () {
        $("#example1").DataTable({
            "responsive": true, "lengthChange": false, "autoWidth": false,
            "buttons": ["csv", "excel", "pdf", "print", "colvis"]
        }).buttons().container().appendTo('#example1_wrapper .col-md-6:eq(0)');
    });
</script>
{% endblock %}
