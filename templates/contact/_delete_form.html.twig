<form method="post" action="{{ path('app_contact_delete', {'id': contact.id}) }}" onsubmit="return confirm('Confirmer la suppression de ce contact ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ contact.id) }}">
    <button class="btn btn-danger btn-sm"><i class="fas fa-trash mr-1"></i> Supprimer</button>
</form>
