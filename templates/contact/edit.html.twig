{% extends 'base.html.twig' %}

{% block title %}Modifier le contact{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('styles/contact.css') }}">
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center" style="background:#fff; border-bottom:2px solid #e9ecef;">
                    <div>
                        <i class="fas fa-edit text-primary mr-2"></i>
                        <span class="font-weight-bold">Modifier le contact</span>
                    </div>
                    <a href="{{ path('app_contact_index') }}" class="btn btn-default btn-sm">
                        <i class="fas fa-arrow-left mr-1"></i> Retour
                    </a>
                </div>
                <div class="card-body">
                    {{ include('contact/_form.html.twig', {'button_label': 'Enregistrer'}) }}
                </div>
                <div class="card-footer d-flex justify-content-between align-items-center" style="background:#fafafa;">
                    <a href="{{ path('app_contact_show', {'id': contact.id}) }}" class="btn btn-default btn-sm">
                        <i class="fas fa-eye mr-1"></i> Voir le détail
                    </a>
                    {{ include('contact/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
