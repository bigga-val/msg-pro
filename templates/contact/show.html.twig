{% extends 'base.html.twig' %}

{% block title %}Contact — {{ contact.nom }} {{ contact.postnom }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('styles/contact.css') }}">
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-7">

            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center" style="background:#fff; border-bottom:2px solid #e9ecef;">
                    <div>
                        <i class="fas fa-user text-primary mr-2"></i>
                        <span class="font-weight-bold">Détail du contact</span>
                    </div>
                    <div>
                        <a href="{{ path('app_contact_edit', {'id': contact.id}) }}" class="btn btn-warning btn-sm mr-1">
                            <i class="fas fa-edit mr-1"></i> Modifier
                        </a>
                        <a href="{{ path('app_contact_index') }}" class="btn btn-default btn-sm">
                            <i class="fas fa-arrow-left mr-1"></i> Retour
                        </a>
                    </div>
                </div>

                <div class="card-body">

                    <!-- Avatar + nom -->
                    <div class="text-center mb-4 pt-2">
                        <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle"
                             style="width:72px;height:72px;background:#eff6ff;font-size:1.6rem;color:#2563eb;font-weight:700;">
                            {{ (contact.nom ?? '?')|first|upper }}
                        </div>
                        <h4 class="mb-0 font-weight-bold">{{ contact.nom }} {{ contact.postnom }}</h4>
                        {% if contact.fonction %}
                            <span class="text-muted" style="font-size:0.9rem;">{{ contact.fonction }}</span>
                        {% endif %}
                    </div>

                    <hr style="border-color:#f1f5f9;">

                    <!-- Infos -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="contact-info-item">
                                <div class="contact-info-label"><i class="fas fa-phone mr-1"></i> Téléphone</div>
                                <div class="contact-info-value">{{ contact.telephone ?? '—' }}</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="contact-info-item">
                                <div class="contact-info-label"><i class="fas fa-map-marker-alt mr-1"></i> Adresse</div>
                                <div class="contact-info-value">{{ contact.adresse ?? '—' }}</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="contact-info-item">
                                <div class="contact-info-label"><i class="fas fa-briefcase mr-1"></i> Fonction</div>
                                <div class="contact-info-value">{{ contact.fonction ?? '—' }}</div>
                            </div>
                        </div>
                    </div>

                    <hr style="border-color:#f1f5f9;">

                    <!-- Groupes -->
                    <div class="mb-2">
                        <div class="contact-info-label mb-2"><i class="fas fa-layer-group mr-1"></i> Groupes</div>
                        {% for cg in contact.contactGroupes %}
                            {% if cg.groupe is not null %}
                                <span class="badge badge-info mr-1">{{ cg.groupe.designation }}</span>
                            {% endif %}
                        {% else %}
                            <span class="text-muted" style="font-size:0.88rem;">Aucun groupe assigné</span>
                        {% endfor %}
                    </div>

                </div>

                <div class="card-footer d-flex justify-content-end" style="background:#fafafa;">
                    {{ include('contact/_delete_form.html.twig') }}
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
