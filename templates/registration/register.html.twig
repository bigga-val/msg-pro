{% extends 'base2.html.twig' %}

{% block title %}Créer un compte gratuit — MSG-PRO | 5 SMS offerts{% endblock %}
{% block meta_description %}Créez votre compte MSG-PRO gratuitement et recevez 5 SMS offerts. Envoyez des SMS en masse sur tous les réseaux en RDC : Vodacom, Airtel, Orange, Africell.{% endblock %}
{% block meta_robots %}index, follow{% endblock %}
{% block canonical %}https://msg-pro.com/register{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/auth.css') }}">
<link rel="stylesheet" href="{{ asset('styles/auth-register.css') }}">
{% endblock %}

{% block body %}
<div class="login-wrapper">

    <!-- Barre mobile (logo + retour accueil) -->
    <div class="mobile-topbar">
        <a href="{{ path('app_landing') }}">
            <img src="{{ asset('msg-logo.PNG') }}" alt="MSG-PRO">
        </a>
        <a href="{{ path('app_landing') }}" class="back-home">
            <i class="fas fa-arrow-left"></i> Accueil
        </a>
    </div>

    <!-- Panneau gauche -->
    <div class="login-brand">
        <div>
            <div class="brand-logo">
                <a href="{{ path('app_landing') }}">
                    <img src="{{ asset('msg-logo.PNG') }}" alt="MSG-PRO">
                </a>
            </div>
            <div class="brand-headline">
                <h2>Rejoignez MSG-PRO dès aujourd'hui</h2>
                <p>Créez votre compte gratuitement et commencez à envoyer des SMS professionnels en RDC.</p>
                <ul class="brand-features">
                    <li><i class="fas fa-gift"></i> 5 SMS offerts dès l'inscription</li>
                    <li><i class="fas fa-infinity"></i> Crédits SMS sans expiration</li>
                    <li><i class="fas fa-network-wired"></i> Tous réseaux — Vodacom, Airtel, Orange, Africell</li>
                    <li><i class="fas fa-headset"></i> Support disponible 24h/7j</li>
                </ul>
            </div>
        </div>
        <div class="brand-footer">
            © {{ "now"|date("Y") }} MSG-PRO — Tous droits réservés
        </div>
    </div>

    <!-- Panneau droit -->
    <div class="login-form-panel">
        <div class="form-title">
            <h3>Créer un compte</h3>
            <p>Remplissez les informations ci-dessous pour commencer</p>
        </div>

        <div id="msg-return">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }}"><span>{{ message }}</span></div>
                {% endfor %}
            {% endfor %}
        </div>

        {{ form_errors(registrationForm) }}
        {{ form_start(registrationForm) }}

        <div class="row-fields">
            <div>
                <label>Nom d'utilisateur *</label>
                {{ form_widget(registrationForm.username, {'attr': {'class': 'form-control', 'placeholder': 'ex: jean_dupont'}}) }}
            </div>
            <div>
                <label>Téléphone *</label>
                {{ form_widget(registrationForm.telephone, {'attr': {'class': 'form-control', 'type': 'telephone', 'required': 'true', 'placeholder': '0851234567'}}) }}
            </div>
        </div>

        <label>Email *</label>
        {{ form_widget(registrationForm.Email, {'attr': {'class': 'form-control', 'type': 'email', 'required': 'true', 'placeholder': 'vous@exemple.com'}}) }}

        <div class="row-fields">
            <div>
                <label>Mot de passe *</label>
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control', 'placeholder': '••••••••'}}) }}
            </div>
            <div>
                <label>Confirmer le mot de passe *</label>
                {{ form_widget(registrationForm.plainPassword2, {'attr': {'class': 'form-control', 'placeholder': '••••••••'}}) }}
            </div>
        </div>

        <div class="terms-row">
            {{ form_widget(registrationForm.agreeTerms) }}
            <label for="registration_form_agreeTerms" class="terms-label">
                J'ai lu et j'accepte les <a href="{{ path('app_cgu') }}" target="_blank">conditions générales d'utilisation</a>
            </label>
        </div>
        {{ form_errors(registrationForm.agreeTerms) }}

        <button type="submit" id="btn-register" class="btn-submit">Créer mon compte</button>

        {{ form_end(registrationForm) }}

        <div class="form-links">
            Déjà un compte ? <a href="{{ path('app_login') }}">Se connecter</a>
        </div>
    </div>

</div>

<script src="https://www.google.com/recaptcha/api.js?render={{ site_key }}"></script>
<script src="{{ asset("plugins/jquery/jquery.min.js") }}"></script>
<script>
    function validateEmail(email) {
        const re = /^(([^<>()[\]\\.,;:\s@"]+(\.[^<>()[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
        return re.test(String(email).toLowerCase());
    }

    function submitAfterRecaptcha(form) {
        if (typeof grecaptcha === 'undefined') {
            form.submit();
            return;
        }
        grecaptcha.ready(function () {
            grecaptcha.execute('{{ site_key }}', { action: 'register' }).then(function (token) {
                document.getElementById('registration_form_captcha').value = token;
                form.submit();
            }).catch(function () {
                form.submit();
            });
        });
    }

    $(document).ready(function () {
        $('form[name="registration_form"]').on('submit', function (e) {
            e.preventDefault();
            let form = this;
            let email    = $("#registration_form_Email").val();
            let username = $("#registration_form_username").val();
            let pwd      = $("#registration_form_plainPassword").val();
            let pwd2     = $("#registration_form_plainPassword2").val();

            if (!validateEmail(email)) {
                $("#msg-return").html('<div class="alert alert-danger">Email invalide.</div>');
                return false;
            }
            if (pwd !== pwd2) {
                $("#msg-return").html('<div class="alert alert-danger">Les mots de passe ne sont pas identiques.</div>');
                return false;
            }
            if (!$("#registration_form_agreeTerms").prop('checked')) {
                $("#msg-return").html('<div class="alert alert-danger">Vous devez accepter les conditions générales d\'utilisation.</div>');
                return false;
            }

            $("#btn-register").prop('disabled', true).text('Vérification...');

            $.ajax({
                url: 'JsonCheckCredentials?email=' + encodeURIComponent(email) + '&username=' + encodeURIComponent(username),
                method: 'GET',
                success: function (data) {
                    if (data !== true) {
                        $("#msg-return").html('<div class="alert alert-danger">' + $('<div>').text(data).html() + '</div>');
                        $("#btn-register").prop('disabled', false).text('Créer mon compte');
                        return;
                    }
                    submitAfterRecaptcha(form);
                },
                error: function () {
                    $("#msg-return").html('<div class="alert alert-danger">Impossible de vérifier vos informations. Vérifiez votre connexion et réessayez.</div>');
                    $("#btn-register").prop('disabled', false).text('Créer mon compte');
                }
            });
        });
    });
</script>
{% endblock %}
{% block javascripts %}{% endblock %}
