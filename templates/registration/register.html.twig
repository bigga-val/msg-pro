{% extends 'base2.html.twig' %}

{% block title %}Créer un compte gratuit — MSG-PRO | 5 SMS offerts{% endblock %}
{% block meta_description %}Créez votre compte MSG-PRO gratuitement et recevez 5 SMS offerts. Envoyez des SMS en masse sur tous les réseaux en RDC : Vodacom, Airtel, Orange, Africell.{% endblock %}
{% block meta_robots %}index, follow{% endblock %}
{% block canonical %}https://msg-pro.com/register{% endblock %}

{% block stylesheets %}
<style>
    html, body.hold-transition.login-page {
        height: 100% !important;
        min-height: 100vh !important;
    }
    body.hold-transition.login-page {
        background: #f1f5f9 !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        padding: 20px !important;
        font-family: 'Source Sans Pro', sans-serif;
    }
    .login-wrapper {
        display: flex;
        width: 100%;
        max-width: 980px;
        min-height: 600px;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    }
    .login-brand {
        flex: 0 0 340px;
        background: linear-gradient(160deg, #1a2e5a 0%, #2563eb 100%);
        padding: 50px 36px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        color: #fff;
    }
    .login-brand .brand-logo img {
        height: 52px;
        width: auto;
        object-fit: contain;
    }
    .login-brand .brand-headline { margin-top: 40px; }
    .login-brand .brand-headline h2 {
        font-size: 1.6rem;
        font-weight: 800;
        line-height: 1.25;
        margin-bottom: 12px;
        color: #fff;
    }
    .login-brand .brand-headline p {
        color: rgba(255,255,255,0.75);
        font-size: 0.93rem;
        line-height: 1.6;
    }
    .login-brand .brand-features {
        list-style: none;
        padding: 0;
        margin: 24px 0 0;
    }
    .login-brand .brand-features li {
        display: flex;
        align-items: center;
        gap: 10px;
        color: rgba(255,255,255,0.85);
        font-size: 0.88rem;
        margin-bottom: 10px;
    }
    .login-brand .brand-features li i {
        background: rgba(255,255,255,0.15);
        border-radius: 50%;
        width: 26px;
        height: 26px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        flex-shrink: 0;
    }
    .login-brand .brand-footer {
        font-size: 0.75rem;
        color: rgba(255,255,255,0.4);
        margin-top: 32px;
    }
    .login-form-panel {
        flex: 1;
        background: #fff;
        padding: 44px 48px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        overflow-y: auto;
    }
    .login-form-panel .form-title { margin-bottom: 24px; }
    .login-form-panel .form-title h3 {
        font-size: 1.55rem;
        font-weight: 800;
        color: #1a2e5a;
        margin-bottom: 4px;
    }
    .login-form-panel .form-title p { color: #888; font-size: 0.92rem; }
    .login-form-panel label {
        font-size: 0.84rem;
        font-weight: 600;
        color: #444;
        margin-bottom: 4px;
        display: block;
    }
    .login-form-panel .form-control,
    .login-form-panel input[type="text"],
    .login-form-panel input[type="email"],
    .login-form-panel input[type="password"],
    .login-form-panel input[type="telephone"] {
        border: 1.5px solid #e2e8f0 !important;
        border-radius: 8px !important;
        padding: 10px 14px !important;
        font-size: 0.93rem !important;
        color: #1e293b !important;
        transition: 0.25s !important;
        width: 100% !important;
        margin-bottom: 14px !important;
        box-shadow: none !important;
    }
    .login-form-panel .form-control:focus,
    .login-form-panel input:focus {
        border-color: #2563eb !important;
        box-shadow: 0 0 0 3px rgba(37,99,235,0.12) !important;
        outline: none !important;
    }
    .login-form-panel .btn-submit {
        width: 100%;
        background: #2563eb;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 13px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: 0.25s;
        margin-top: 6px;
        letter-spacing: 0.3px;
    }
    .login-form-panel .btn-submit:hover { background: #1d4ed8; }
    .login-form-panel .form-links {
        margin-top: 18px;
        font-size: 0.88rem;
        color: #888;
        text-align: center;
    }
    .login-form-panel .form-links a {
        color: #2563eb;
        font-weight: 600;
        text-decoration: none;
    }
    .login-form-panel .form-links a:hover { text-decoration: underline; }
    .row-fields { display: flex; gap: 14px; }
    .row-fields > div { flex: 1; }
    #msg-return .alert {
        border-radius: 8px;
        font-size: 0.88rem;
        background-color: #fff3cd;
        border-color: #e67e22;
        color: #7d3c00;
    }
    /* Mobile top bar */
    .mobile-topbar {
        display: none;
        background: linear-gradient(90deg, #1a2e5a 0%, #2563eb 100%);
        padding: 14px 20px;
        align-items: center;
        justify-content: space-between;
        width: 100%;
    }
    .mobile-topbar a.back-home {
        color: rgba(255,255,255,0.85);
        font-size: 0.85rem;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .mobile-topbar a.back-home:hover { color: #fff; }
    .mobile-topbar img { height: 32px; width: auto; }

    @media (max-width: 700px) {
        .login-brand { display: none; }
        .mobile-topbar { display: flex; }
        .login-form-panel { padding: 28px 24px; }
        .login-wrapper {
            max-width: 100%;
            border-radius: 16px;
            flex-direction: column;
        }
        .row-fields { flex-direction: column; gap: 0; }
    }
</style>
{% endblock %}

{% block body %}
<div class="login-wrapper">

    <!-- Barre mobile (logo + retour accueil) -->
    <div class="mobile-topbar">
        <a href="{{ path('app_landing') }}">
            <img src="{{ asset('msg-logo.PNG') }}" alt="MSG-PRO">
        </a>
        <a href="{{ path('app_landing') }}" class="back-home">
            <i class="fas fa-arrow-left"></i> Accueil
        </a>
    </div>

    <!-- Panneau gauche -->
    <div class="login-brand">
        <div>
            <div class="brand-logo">
                <a href="{{ path('app_landing') }}">
                    <img src="{{ asset('msg-logo.PNG') }}" alt="MSG-PRO">
                </a>
            </div>
            <div class="brand-headline">
                <h2>Rejoignez MSG-PRO dès aujourd'hui</h2>
                <p>Créez votre compte gratuitement et commencez à envoyer des SMS professionnels en RDC.</p>
                <ul class="brand-features">
                    <li><i class="fas fa-gift"></i> 5 SMS offerts dès l'inscription</li>
                    <li><i class="fas fa-infinity"></i> Crédits SMS sans expiration</li>
                    <li><i class="fas fa-network-wired"></i> Tous réseaux — Vodacom, Airtel, Orange, Africell</li>
                    <li><i class="fas fa-headset"></i> Support disponible 24h/7j</li>
                </ul>
            </div>
        </div>
        <div class="brand-footer">
            © {{ "now"|date("Y") }} MSG-PRO — Tous droits réservés
        </div>
    </div>

    <!-- Panneau droit -->
    <div class="login-form-panel">
        <div class="form-title">
            <h3>Créer un compte</h3>
            <p>Remplissez les informations ci-dessous pour commencer</p>
        </div>

        <div id="msg-return">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }}"><span>{{ message }}</span></div>
                {% endfor %}
            {% endfor %}
        </div>

        {{ form_errors(registrationForm) }}
        {{ form_start(registrationForm) }}

        <div class="row-fields">
            <div>
                <label>Nom d'utilisateur *</label>
                {{ form_widget(registrationForm.username, {'attr': {'class': 'form-control', 'placeholder': 'ex: jean_dupont'}}) }}
            </div>
            <div>
                <label>Téléphone *</label>
                {{ form_widget(registrationForm.telephone, {'attr': {'class': 'form-control', 'type': 'telephone', 'required': 'true', 'placeholder': '0851234567'}}) }}
            </div>
        </div>

        <label>Email *</label>
        {{ form_widget(registrationForm.Email, {'attr': {'class': 'form-control', 'type': 'email', 'required': 'true', 'placeholder': 'vous@exemple.com'}}) }}

        <div class="row-fields">
            <div>
                <label>Mot de passe *</label>
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control', 'placeholder': '••••••••'}}) }}
            </div>
            <div>
                <label>Confirmer le mot de passe *</label>
                {{ form_widget(registrationForm.plainPassword2, {'attr': {'class': 'form-control', 'placeholder': '••••••••'}}) }}
            </div>
        </div>

        <div style="display:flex; align-items:flex-start; gap:10px; margin-bottom:14px;">
            {{ form_widget(registrationForm.agreeTerms) }}
            <label for="registration_form_agreeTerms" style="font-size:0.85rem; font-weight:400; color:#555; margin:0; cursor:pointer;">
                J'ai lu et j'accepte les <a href="{{ path('app_cgu') }}" target="_blank" style="color:#2563eb; font-weight:600;">conditions générales d'utilisation</a>
            </label>
        </div>
        {{ form_errors(registrationForm.agreeTerms) }}

        <button type="submit" id="btn-register" class="btn-submit">Créer mon compte</button>

        {{ form_end(registrationForm) }}

        <div class="form-links">
            Déjà un compte ? <a href="{{ path('app_login') }}">Se connecter</a>
        </div>
    </div>

</div>

<script src="https://www.google.com/recaptcha/api.js?render={{ site_key }}"></script>
<script src="{{ asset("plugins/jquery/jquery.min.js") }}"></script>
<script>
    function validateEmail(email) {
        const re = /^(([^<>()[\]\\.,;:\s@"]+(\.[^<>()[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
        return re.test(String(email).toLowerCase());
    }

    function submitAfterRecaptcha(form) {
        {% if app.environment == 'dev' %}
        form.submit();
        return;
        {% endif %}
        if (typeof grecaptcha === 'undefined') {
            form.submit();
            return;
        }
        grecaptcha.ready(function () {
            grecaptcha.execute('{{ site_key }}', { action: 'register' }).then(function (token) {
                document.getElementById('registration_form_captcha').value = token;
                $.ajax({
                    url: 'JsonVerifyRecaptcha?token=' + encodeURIComponent(token),
                    method: 'GET',
                    success: function (data) {
                        if (data["success"] === true && data["score"] > 0.5) {
                            form.submit();
                        } else {
                            $("#msg-return").html('<div class="alert alert-danger">Vérification anti-robot échouée. Veuillez rafraîchir la page.</div>');
                            $("#btn-register").prop('disabled', false).text('Créer mon compte');
                        }
                    },
                    error: function () {
                        form.submit();
                    }
                });
            });
        });
    }

    $(document).ready(function () {
        $('form[name="registration_form"]').on('submit', function (e) {
            e.preventDefault();
            let form = this;
            let email    = $("#registration_form_Email").val();
            let username = $("#registration_form_username").val();
            let pwd      = $("#registration_form_plainPassword").val();
            let pwd2     = $("#registration_form_plainPassword2").val();

            if (!validateEmail(email)) {
                $("#msg-return").html('<div class="alert alert-danger">Email invalide.</div>');
                return false;
            }
            if (pwd !== pwd2) {
                $("#msg-return").html('<div class="alert alert-danger">Les mots de passe ne sont pas identiques.</div>');
                return false;
            }
            if (!$("#registration_form_agreeTerms").prop('checked')) {
                $("#msg-return").html('<div class="alert alert-danger">Vous devez accepter les conditions générales d\'utilisation.</div>');
                return false;
            }

            $("#btn-register").prop('disabled', true).text('Vérification...');

            $.ajax({
                url: 'JsonCheckCredentials?email=' + encodeURIComponent(email) + '&username=' + encodeURIComponent(username),
                method: 'GET',
                success: function (data) {
                    if (data !== true) {
                        $("#msg-return").html('<div class="alert alert-danger">' + $('<div>').text(data).html() + '</div>');
                        $("#btn-register").prop('disabled', false).text('Créer mon compte');
                        return;
                    }
                    submitAfterRecaptcha(form);
                },
                error: function () {
                    $("#msg-return").html('<div class="alert alert-danger">Une erreur est survenue. Veuillez réessayer.</div>');
                    $("#btn-register").prop('disabled', false).text('Créer mon compte');
                }
            });
        });
    });
</script>
{% endblock %}
{% block javascripts %}{% endblock %}
