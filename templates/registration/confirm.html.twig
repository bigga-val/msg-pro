{% extends 'base2.html.twig' %}

{% block title %}Confirmez votre compte — MSG-PRO{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/auth-confirm.css') }}">
{% endblock %}

{% block body %}
<div class="confirm-card">
    <div class="confirm-logo">
        <a href="{{ path('app_landing') }}">
            <img src="{{ asset('msg-logo.PNG') }}" alt="MSG-PRO">
        </a>
    </div>

    <div class="confirm-icon">
        <i class="fas fa-envelope-open-text"></i>
    </div>

    <h2>Vérifiez votre boîte mail</h2>

    <p>Votre compte a bien été créé. Nous venons de vous envoyer un email de confirmation à l'adresse que vous avez indiquée.</p>

    <div class="confirm-steps">
        <p><i class="fas fa-check-circle"></i> <span>Ouvrez votre boîte email et cherchez un message de <strong>info@msg-pro.com</strong></span></p>
        <p><i class="fas fa-check-circle"></i> <span>Cliquez sur le lien <strong>« Votre lien unique »</strong> pour activer votre compte</span></p>
        <p><i class="fas fa-check-circle"></i> <span>Une fois activé, vous recevrez <strong>5 SMS gratuits</strong> pour commencer</span></p>
        <p><i class="fas fa-exclamation-circle icon-warning"></i> <span>Pensez à vérifier vos <strong>spams</strong> si vous ne voyez pas l'email</span></p>
    </div>

    <p class="text-contact">Un problème ? Contactez-nous sur <a href="mailto:info@msg-pro.com">info@msg-pro.com</a> ou au +243 851 331 051</p>

    <a href="{{ path('app_landing') }}" class="btn-home">Retour à l'accueil</a>
</div>
{% endblock %}

{% block javascripts %}{% endblock %}
