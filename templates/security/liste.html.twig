{% extends 'base.html.twig' %}

{% block title %}Liste des Utilisateurs{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/liste.css') }}">
{% endblock %}

{% block body %}
<div class="container-fluid">

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show mb-3">
                {{ message }}
                <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# Stats globales #}
    <div class="row mb-2">
        <div class="col-md-4">
            <div class="stat-card stat-blue">
                <div class="stat-value">{{ users|length }}</div>
                <div class="stat-label">Utilisateurs inscrits</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card stat-green">
                <div class="stat-value">{{ users|filter(u => u.confirmer)|length }}</div>
                <div class="stat-label">Comptes actifs</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card stat-orange">
                {% set totalSms = 0 %}
                {% for u in users %}{% set totalSms = totalSms + (u.totalSms ?? 0) %}{% endfor %}
                <div class="stat-value">{{ totalSms }}</div>
                <div class="stat-label">SMS restants (total)</div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-gradient-dark d-flex align-items-center justify-content-between">
                    <h3 class="mb-0">Liste des Utilisateurs</h3>
                    <span class="badge badge-light badge-count">{{ users|length }} utilisateurs</span>
                </div>
                <div class="card-body p-0">
                    <table class="table datatable table-hover mb-0">
                        <thead class="thead-light">
                        <tr>
                            <th class="col-index">#</th>
                            <th>Utilisateur</th>
                            <th>Email</th>
                            <th>Téléphone</th>
                            <th>Statut</th>
                            <th>SMS restants</th>
                            <th>SMS utilisés</th>
                            <th>Inscription</th>
                            <th>Action</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for user in users %}
                            <tr>
                                <td class="text-muted">{{ loop.index }}</td>
                                <td>
                                    <strong>{{ user.username }}</strong>
                                    {% if 'ROLE_ADMIN' in user.roles %}
                                        <span class="badge badge-warning ml-1 badge-admin">Admin</span>
                                    {% endif %}
                                </td>
                                <td>{{ user.email ?? '-' }}</td>
                                <td>{{ user.telephone ?? '-' }}</td>
                                <td>
                                    {% if user.confirmer %}
                                        <span class="badge-sms badge-actif">Actif</span>
                                    {% else %}
                                        <span class="badge-sms badge-inactif">Inactif</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% set total = user.totalSms ?? 0 %}
                                    {% set used  = user.usedSms  ?? 0 %}
                                    {% set grand  = total + used %}
                                    <strong>{{ total }}</strong>
                                    {% if grand > 0 %}
                                    <div class="sms-bar-wrap mt-1">
                                        <div class="sms-bar" style="width: {{ ((total / grand) * 100)|round }}%"></div>
                                    </div>
                                    {% endif %}
                                </td>
                                <td class="text-muted">{{ user.usedSms ?? 0 }}</td>
                                <td class="text-muted col-date">
                                    {% if user.dateCreation is not null %}
                                        {{ user.dateCreation | format_datetime(pattern='dd/MM/yyyy') }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                                <td class="col-actions">
                                    <a href="{{ path('app_user_detail', {id: user.id}) }}"
                                       class="btn btn-sm btn-secondary mr-1">
                                        <i class="fas fa-eye mr-1"></i> Détails
                                    </a>
                                    <span id="{{ user.id }}"
                                          title="{{ user.username }}"
                                          type="button"
                                          class="btn-recharge btn btn-sm btn-primary mr-1"
                                          data-toggle="modal"
                                          data-target="#modal-recharge">
                                        <i class="fas fa-plus-circle mr-1"></i> Recharger
                                    </span>
                                    <form action="{{ path('app_toggle_user', {id: user.id}) }}" method="POST" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_user_' ~ user.id) }}">
                                        {% if user.confirmer %}
                                            <button type="submit" class="btn btn-sm btn-warning"
                                                    onclick="return confirm('Désactiver {{ user.username }} ?')">
                                                <i class="fas fa-ban mr-1"></i> Désactiver
                                            </button>
                                        {% else %}
                                            <button type="submit" class="btn btn-sm btn-success"
                                                    onclick="return confirm('Activer {{ user.username }} ?')">
                                                <i class="fas fa-check-circle mr-1"></i> Activer
                                            </button>
                                        {% endif %}
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="9" class="text-center text-muted py-4">Aucun utilisateur trouvé</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

{# Modal recharge #}
<div class="modal fade" id="modal-recharge">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Recharger <strong id="user_name"></strong></h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <form action="{{ path('app_user_recharge') }}" method="POST">
                <div class="modal-body">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('recharge') }}">
                    <input type="hidden" name="user" id="user_id_input">
                    <div class="form-group mb-0">
                        <label class="modal-label">Nombre de SMS à ajouter</label>
                        <input name="quantite" type="number" min="1" class="form-control" placeholder="ex: 100" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default btn-sm" data-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-bolt mr-1"></i>Recharger</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="{{ asset('plugins/jquery/jquery.min.js') }}"></script>
<script>
$(document).ready(function () {
    $('.btn-recharge').on('click', function () {
        $('#user_id_input').val($(this).attr('id'));
        $('#user_name').text($(this).attr('title'));
    });
});
</script>
{% endblock %}
