{% extends 'base.html.twig' %}

{% block title %}Détails — {{ user.username }}{% endblock %}

{% block stylesheets %}
<style>
    .detail-header {
        background: linear-gradient(135deg, #1a2e5a 0%, #2563eb 100%);
        padding: 28px 32px;
        border-radius: 12px 12px 0 0;
        color: #fff;
        display: flex; align-items: center; gap: 20px;
    }
    .detail-avatar {
        width: 72px; height: 72px; border-radius: 50%;
        background: rgba(255,255,255,0.2);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.8rem; font-weight: 800; color: #fff;
        flex-shrink: 0; overflow: hidden;
        border: 3px solid rgba(255,255,255,0.35);
    }
    .detail-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .detail-header h4 { margin: 0; font-size: 1.25rem; font-weight: 800; }
    .detail-header p  { margin: 2px 0 0; opacity: 0.75; font-size: 0.85rem; }
    .badge-actif   { background:#d1fae5; color:#065f46; padding:3px 10px; border-radius:20px; font-size:0.78rem; font-weight:700; }
    .badge-inactif { background:#fee2e2; color:#991b1b; padding:3px 10px; border-radius:20px; font-size:0.78rem; font-weight:700; }
    .stat-box {
        border-radius: 10px; padding: 16px 18px; text-align: center; flex: 1;
    }
    .stat-box .val { font-size: 1.7rem; font-weight: 800; line-height: 1; }
    .stat-box .lbl { font-size: 0.75rem; margin-top: 4px; opacity: 0.8; }
    .s-blue  { background: linear-gradient(135deg,#1a2e5a,#2563eb); color:#fff; }
    .s-green { background: linear-gradient(135deg,#065f46,#10b981); color:#fff; }
    .s-gray  { background: #f1f5f9; color:#334155; }
    .s-orange{ background: linear-gradient(135deg,#92400e,#f59e0b); color:#fff; }
    .info-row { display:flex; align-items:center; padding:11px 0; border-bottom:1px solid #f1f5f9; }
    .info-row:last-child { border-bottom: none; }
    .info-icon { width:32px; height:32px; border-radius:8px; background:#eff6ff;
        display:flex; align-items:center; justify-content:center; color:#2563eb;
        margin-right:12px; flex-shrink:0; font-size:0.85rem; }
    .info-label { font-size:0.75rem; color:#94a3b8; font-weight:700; text-transform:uppercase; letter-spacing:.4px; }
    .info-value { font-size:0.93rem; color:#1e293b; font-weight:600; }
    .section-title { font-size:0.8rem; font-weight:700; text-transform:uppercase;
        letter-spacing:.5px; color:#94a3b8; margin:0 0 12px; }
    .sms-progress { background:#e2e8f0; border-radius:8px; height:7px; overflow:hidden; margin-top:6px; }
    .sms-progress-bar { background:linear-gradient(90deg,#2563eb,#60a5fa); height:7px; border-radius:8px; }
    .table-sm td, .table-sm th { font-size: 0.85rem; vertical-align: middle; }
    .code-success { color: #10b981; font-weight: 700; }
    .code-fail    { color: #ef4444; font-weight: 700; }
    .org-badge {
        display:inline-flex; align-items:center; gap:6px;
        background:#eff6ff; color:#2563eb; border-radius:20px;
        padding:4px 12px; font-size:0.82rem; font-weight:600; margin:3px;
    }
    .org-badge.approved { background:#d1fae5; color:#065f46; }
</style>
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center pt-3">
        <div class="col-xl-10 col-12">

            <div class="mb-3">
                <a href="{{ path('app_liste_users') }}" class="btn btn-sm btn-light">
                    <i class="fas fa-arrow-left mr-1"></i> Retour à la liste
                </a>
            </div>

            <div class="row">

                {# ── Colonne gauche : infos + stats ── #}
                <div class="col-lg-4 mb-4">
                    <div class="card" style="border-radius:12px; overflow:hidden; box-shadow:0 4px 20px rgba(0,0,0,0.08);">
                        <div class="detail-header">
                            <div class="detail-avatar">
                                {% if user.avatar %}
                                    <img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" alt="avatar">
                                {% else %}
                                    {{ user.username|first|upper }}
                                {% endif %}
                            </div>
                            <div>
                                <h4>{{ user.username }}</h4>
                                <p>{{ user.email ?? 'Aucun email' }}</p>
                                <div style="margin-top:6px;">
                                    {% if user.isConfirmer() %}
                                        <span class="badge-actif">Actif</span>
                                    {% else %}
                                        <span class="badge-inactif">Inactif</span>
                                    {% endif %}
                                    {% if 'ROLE_ADMIN' in user.roles %}
                                        <span style="background:rgba(255,255,255,0.2);color:#fff;padding:3px 10px;border-radius:20px;font-size:0.75rem;font-weight:700;margin-left:4px;">Admin</span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        <div class="card-body" style="padding:20px 22px;">
                            {# Stats SMS #}
                            {% set total = user.totalSms ?? 0 %}
                            {% set used  = user.usedSms  ?? 0 %}
                            {% set grand = total + used %}
                            <div class="d-flex mb-3" style="gap:8px;">
                                <div class="stat-box s-blue">
                                    <div class="val">{{ total }}</div>
                                    <div class="lbl">Restants</div>
                                </div>
                                <div class="stat-box s-green">
                                    <div class="val">{{ used }}</div>
                                    <div class="lbl">Envoyés</div>
                                </div>
                                <div class="stat-box s-orange">
                                    <div class="val">{{ nbContacts }}</div>
                                    <div class="lbl">Contacts</div>
                                </div>
                            </div>
                            {% if grand > 0 %}
                            <div class="mb-3">
                                <div style="font-size:0.78rem;color:#64748b;margin-bottom:3px;">
                                    {{ ((used / grand)*100)|round }}% utilisés
                                </div>
                                <div class="sms-progress">
                                    <div class="sms-progress-bar" style="width:{{ ((used / grand)*100)|round }}%"></div>
                                </div>
                            </div>
                            {% endif %}

                            {# Infos #}
                            <div class="info-row">
                                <div class="info-icon"><i class="fas fa-user"></i></div>
                                <div>
                                    <div class="info-label">Username</div>
                                    <div class="info-value">{{ user.username }}</div>
                                </div>
                            </div>
                            <div class="info-row">
                                <div class="info-icon"><i class="fas fa-envelope"></i></div>
                                <div>
                                    <div class="info-label">Email</div>
                                    <div class="info-value">{{ user.email ?? '-' }}</div>
                                </div>
                            </div>
                            <div class="info-row">
                                <div class="info-icon"><i class="fas fa-phone"></i></div>
                                <div>
                                    <div class="info-label">Téléphone</div>
                                    <div class="info-value">{{ user.telephone ?? '-' }}</div>
                                </div>
                            </div>
                            <div class="info-row">
                                <div class="info-icon"><i class="fas fa-calendar-alt"></i></div>
                                <div>
                                    <div class="info-label">Inscription</div>
                                    <div class="info-value">
                                        {% if user.dateCreation %}
                                            {{ user.dateCreation|format_datetime(pattern='dd/MM/yyyy') }}
                                        {% else %}-{% endif %}
                                    </div>
                                </div>
                            </div>
                            <div class="info-row">
                                <div class="info-icon"><i class="fas fa-building"></i></div>
                                <div>
                                    <div class="info-label">Organisations</div>
                                    <div class="info-value">{{ organisations|length }}</div>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer" style="background:#f8fafc; padding:14px 22px; display:flex; gap:8px;">
                            <form action="{{ path('app_toggle_user', {id: user.id}) }}" method="POST" style="flex:1;">
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle_user_' ~ user.id) }}">
                                {% if user.isConfirmer() %}
                                    <button type="submit" class="btn btn-warning btn-sm btn-block"
                                            onclick="return confirm('Désactiver {{ user.username }} ?')">
                                        <i class="fas fa-ban mr-1"></i> Désactiver
                                    </button>
                                {% else %}
                                    <button type="submit" class="btn btn-success btn-sm btn-block"
                                            onclick="return confirm('Activer {{ user.username }} ?')">
                                        <i class="fas fa-check-circle mr-1"></i> Activer
                                    </button>
                                {% endif %}
                            </form>
                            <button class="btn btn-primary btn-sm" data-toggle="modal" data-target="#modal-recharge"
                                    id="{{ user.id }}" title="{{ user.username }}">
                                <i class="fas fa-plus-circle"></i>
                            </button>
                        </div>
                    </div>

                    {# Organisations #}
                    {% if organisations|length > 0 %}
                    <div class="card mt-3" style="border-radius:12px; box-shadow:0 2px 12px rgba(0,0,0,0.06);">
                        <div class="card-body" style="padding:18px 20px;">
                            <p class="section-title"><i class="fas fa-building mr-1"></i> Expéditeurs / Organisations</p>
                            {% for org in organisations %}
                                <span class="org-badge {{ org.isApproved ? 'approved' : '' }}">
                                    {% if org.isApproved %}
                                        <i class="fas fa-check-circle"></i>
                                    {% else %}
                                        <i class="fas fa-clock"></i>
                                    {% endif %}
                                    {{ org.designation }}
                                </span>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                </div>

                {# ── Colonne droite : historique recharges + SMS ── #}
                <div class="col-lg-8">

                    {# Historique recharges #}
                    <div class="card mb-4" style="border-radius:12px; box-shadow:0 2px 12px rgba(0,0,0,0.06);">
                        <div class="card-header" style="background:#f8fafc; border-radius:12px 12px 0 0; padding:14px 20px;">
                            <p class="section-title mb-0"><i class="fas fa-bolt mr-1"></i> Historique des recharges ({{ recharges|length }})</p>
                        </div>
                        <div class="card-body p-0">
                            {% if recharges|length > 0 %}
                            <table class="table table-sm table-hover mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Par</th>
                                        <th>Ancienne balance</th>
                                        <th>Ajout</th>
                                        <th>Nouvelle balance</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                {% for r in recharges %}
                                <tr>
                                    <td class="text-muted">{{ loop.index }}</td>
                                    <td>{{ r.utilisateur ? r.utilisateur.username : '-' }}</td>
                                    <td>{{ r.oldQuantite ?? 0 }}</td>
                                    <td><span style="color:#10b981; font-weight:700;">+{{ r.quantite }}</span></td>
                                    <td><strong>{{ (r.oldQuantite ?? 0) + (r.quantite ?? 0) }}</strong></td>
                                    <td class="text-muted">
                                        {% if r.date %}{{ r.date|format_datetime(pattern='dd/MM/yyyy HH:mm') }}{% else %}-{% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                            {% else %}
                                <p class="text-muted text-center py-3 mb-0" style="font-size:0.88rem;">Aucune recharge pour cet utilisateur.</p>
                            {% endif %}
                        </div>
                    </div>

                    {# Historique SMS #}
                    <div class="card" style="border-radius:12px; box-shadow:0 2px 12px rgba(0,0,0,0.06);">
                        <div class="card-header" style="background:#f8fafc; border-radius:12px 12px 0 0; padding:14px 20px;">
                            <p class="section-title mb-0"><i class="fas fa-paper-plane mr-1"></i> Derniers SMS envoyés ({{ historiques|length }})</p>
                        </div>
                        <div class="card-body p-0">
                            {% if historiques|length > 0 %}
                            <table class="table table-sm table-hover mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Destinataire</th>
                                        <th>Expéditeur</th>
                                        <th>Message</th>
                                        <th>Statut</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                {% for h in historiques %}
                                <tr>
                                    <td class="text-muted">{{ loop.index }}</td>
                                    <td>{{ h.numero ?? '-' }}</td>
                                    <td><span style="background:#eff6ff;color:#2563eb;padding:2px 8px;border-radius:10px;font-size:0.78rem;font-weight:600;">{{ h.sender ?? '-' }}</span></td>
                                    <td style="max-width:220px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="{{ h.message }}">
                                        {{ h.message|length > 50 ? h.message|slice(0,50) ~ '…' : h.message ?? '-' }}
                                    </td>
                                    <td>
                                        {% if h.reponse == '0' or h.reponse == 0 %}
                                            <span class="code-success"><i class="fas fa-check-circle"></i> Envoyé</span>
                                        {% else %}
                                            <span class="code-fail"><i class="fas fa-times-circle"></i> Échec</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-muted" style="font-size:0.82rem;">
                                        {% if h.date %}{{ h.date|format_datetime(pattern='dd/MM HH:mm') }}{% else %}-{% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                            {% else %}
                                <p class="text-muted text-center py-3 mb-0" style="font-size:0.88rem;">Aucun SMS envoyé par cet utilisateur.</p>
                            {% endif %}
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

{# Modal recharge #}
<div class="modal fade" id="modal-recharge">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Recharger <strong>{{ user.username }}</strong></h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <form action="{{ path('app_user_recharge') }}" method="POST">
                <div class="modal-body">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('recharge') }}">
                    <input type="hidden" name="user" value="{{ user.id }}">
                    <div class="form-group mb-0">
                        <label style="font-size:0.85rem; font-weight:600;">Nombre de SMS à ajouter</label>
                        <input name="quantite" type="number" min="1" class="form-control" placeholder="ex: 100" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default btn-sm" data-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-bolt mr-1"></i> Recharger</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
