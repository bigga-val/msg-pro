{% extends 'base.html.twig' %}

{% block title %}Mon Profil — {{ app.user.username }}{% endblock %}

{% block stylesheets %}
<style>
    .profile-avatar {
        width: 80px; height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1a2e5a, #2563eb);
        display: flex; align-items: center; justify-content: center;
        font-size: 2rem; font-weight: 800; color: #fff;
        flex-shrink: 0;
    }
    .profile-header {
        display: flex; align-items: center; gap: 20px;
        padding: 24px 28px;
        background: linear-gradient(135deg, #1a2e5a 0%, #2563eb 100%);
        color: #fff;
        border-radius: 12px 12px 0 0;
    }
    .profile-header h4 { margin: 0; font-size: 1.3rem; font-weight: 800; }
    .profile-header p  { margin: 0; opacity: 0.8; font-size: 0.88rem; }
    .sms-stat {
        border-radius: 10px;
        padding: 16px 20px;
        text-align: center;
        flex: 1;
    }
    .sms-stat .val { font-size: 1.9rem; font-weight: 800; line-height: 1; }
    .sms-stat .lbl { font-size: 0.78rem; margin-top: 4px; opacity: 0.75; }
    .stat-blue  { background: linear-gradient(135deg,#1a2e5a,#2563eb); color:#fff; }
    .stat-green { background: linear-gradient(135deg,#065f46,#10b981); color:#fff; }
    .stat-gray  { background: #f1f5f9; color: #334155; }
    .info-row { display: flex; align-items: center; padding: 13px 0; border-bottom: 1px solid #f1f5f9; }
    .info-row:last-child { border-bottom: none; }
    .info-row .info-icon { width: 34px; height: 34px; border-radius: 8px; background:#eff6ff;
        display:flex; align-items:center; justify-content:center; color:#2563eb; margin-right:14px; flex-shrink:0; }
    .info-row .info-label { font-size: 0.78rem; color: #94a3b8; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
    .info-row .info-value { font-size: 0.95rem; color: #1e293b; font-weight: 600; }
    .badge-actif   { background:#d1fae5; color:#065f46; padding:3px 10px; border-radius:20px; font-size:0.8rem; font-weight:700; }
    .badge-inactif { background:#fee2e2; color:#991b1b; padding:3px 10px; border-radius:20px; font-size:0.8rem; font-weight:700; }
    .sms-progress { background:#e2e8f0; border-radius:8px; height:8px; overflow:hidden; margin-top:8px; }
    .sms-progress-bar { background: linear-gradient(90deg,#2563eb,#60a5fa); height:8px; border-radius:8px; transition:.4s; }
</style>
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center pt-3">
        <div class="col-lg-7 col-md-9 col-12">

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }} alert-dismissible fade show mb-3">
                        {{ message }}
                        <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                    </div>
                {% endfor %}
            {% endfor %}

            <div class="card" style="border-radius:12px; overflow:hidden; box-shadow:0 4px 24px rgba(0,0,0,0.08);">

                {# Header #}
                <div class="profile-header">
                    <div class="profile-avatar" style="overflow:hidden; padding:0;">
                        {% if app.user.avatar %}
                            <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}"
                                 alt="avatar"
                                 style="width:100%; height:100%; object-fit:cover; border-radius:50%;">
                        {% else %}
                            {{ app.user.username|first|upper }}
                        {% endif %}
                    </div>
                    <div>
                        <h4>{{ app.user.username }}</h4>
                        <p>{{ app.user.email ?? 'Aucun email renseigné' }}</p>
                        <div style="margin-top:6px;">
                            {% if app.user.isConfirmer() %}
                                <span class="badge-actif">Compte actif</span>
                            {% else %}
                                <span class="badge-inactif">Compte inactif</span>
                            {% endif %}
                            {% if is_granted('ROLE_ADMIN') %}
                                <span style="background:rgba(255,255,255,0.2); color:#fff; padding:3px 10px; border-radius:20px; font-size:0.8rem; font-weight:700; margin-left:6px;">Admin</span>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <div class="card-body" style="padding: 24px 28px;">

                    {# Solde SMS #}
                    {% set total = app.user.totalSms ?? 0 %}
                    {% set used  = app.user.usedSms  ?? 0 %}
                    {% set grand = total + used %}
                    <div class="d-flex gap-3 mb-4" style="gap:12px; display:flex;">
                        <div class="sms-stat stat-blue">
                            <div class="val">{{ total }}</div>
                            <div class="lbl">SMS restants</div>
                        </div>
                        <div class="sms-stat stat-green">
                            <div class="val">{{ used }}</div>
                            <div class="lbl">SMS envoyés</div>
                        </div>
                        <div class="sms-stat stat-gray">
                            <div class="val">{{ grand }}</div>
                            <div class="lbl">Total reçus</div>
                        </div>
                    </div>
                    {% if grand > 0 %}
                    <div class="mb-4">
                        <div style="font-size:0.8rem; color:#64748b; margin-bottom:4px;">
                            Utilisation : {{ ((used / grand) * 100)|round }}% des SMS utilisés
                        </div>
                        <div class="sms-progress">
                            <div class="sms-progress-bar" style="width:{{ ((used / grand) * 100)|round }}%"></div>
                        </div>
                    </div>
                    {% endif %}

                    {# Infos personnelles #}
                    <div class="info-row">
                        <div class="info-icon"><i class="fas fa-user"></i></div>
                        <div>
                            <div class="info-label">Nom d'utilisateur</div>
                            <div class="info-value">{{ app.user.username }}</div>
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon"><i class="fas fa-envelope"></i></div>
                        <div>
                            <div class="info-label">Email</div>
                            <div class="info-value">{{ app.user.email ?? '-' }}</div>
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon"><i class="fas fa-phone"></i></div>
                        <div>
                            <div class="info-label">Téléphone</div>
                            <div class="info-value">{{ app.user.telephone ?? '-' }}</div>
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon"><i class="fas fa-calendar-alt"></i></div>
                        <div>
                            <div class="info-label">Membre depuis</div>
                            <div class="info-value">
                                {% if app.user.dateCreation is not null %}
                                    {{ app.user.dateCreation | format_datetime(pattern='dd MMMM yyyy') }}
                                {% else %}
                                    -
                                {% endif %}
                            </div>
                        </div>
                    </div>

                </div>

                <div class="card-footer" style="background:#f8fafc; padding:16px 28px;">
                    <a href="{{ path('edit_profile') }}" class="btn btn-primary btn-sm">
                        <i class="fas fa-pen mr-1"></i> Modifier mon profil
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>
{% endblock %}
