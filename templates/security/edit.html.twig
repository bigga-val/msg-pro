{% extends 'base.html.twig' %}

{% block title %}Modifier mon profil — {{ app.user.username }}{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/edit-profile.css') }}">
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center pt-3">
        <div class="col-lg-6 col-md-8 col-12">

            <div class="card card-elevated">

                <div class="edit-header">
                    <label for="avatar-input" class="avatar-wrap mb-0" title="Changer la photo">
                        {% if app.user.avatar %}
                            <img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}"
                                 class="avatar-preview" id="avatar-img" alt="avatar">
                        {% else %}
                            <div class="avatar-initial" id="avatar-img-placeholder">
                                {{ app.user.username|first|upper }}
                            </div>
                        {% endif %}
                        <div class="avatar-overlay"><i class="fas fa-camera"></i></div>
                    </label>
                    <div>
                        <h4>Modifier mon profil</h4>
                        <p>Cliquez sur la photo pour la changer</p>
                    </div>
                </div>

                <div class="card-body card-body-form">
                    <form action="" method="POST" enctype="multipart/form-data">
                        <input type="hidden" name="profile_token" value="{{ csrf_token('profile') }}">
                        <input type="file" id="avatar-input" name="avatar" accept="image/jpeg,image/png,image/webp,image/gif">

                        <div class="field-group">
                            <label><i class="fas fa-user"></i> Nom d'utilisateur</label>
                            <input name="username" type="text" class="form-control"
                                   value="{{ app.user.username }}" required>
                        </div>

                        <div class="field-group">
                            <label><i class="fas fa-envelope"></i> Adresse email</label>
                            <input name="email" type="email" class="form-control"
                                   value="{{ app.user.email }}" placeholder="vous@exemple.com">
                        </div>

                        <div class="field-group">
                            <label><i class="fas fa-phone"></i> Téléphone</label>
                            <input name="telephone" type="tel" class="form-control"
                                   value="{{ app.user.telephone }}" placeholder="0851234567">
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn-save">
                                <i class="fas fa-save mr-1"></i> Enregistrer
                            </button>
                            <a href="{{ path('app_profile') }}" class="btn-cancel">
                                Annuler
                            </a>
                        </div>
                    </form>
                </div>

            </div>

        </div>
    </div>
</div>

<script>
document.getElementById('avatar-input').addEventListener('change', function () {
    const file = this.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function (e) {
        const placeholder = document.getElementById('avatar-img-placeholder');
        let img = document.getElementById('avatar-img');
        if (placeholder) {
            // Remplacer le div initial par une vraie image
            img = document.createElement('img');
            img.className = 'avatar-preview';
            img.id = 'avatar-img';
            placeholder.replaceWith(img);
        }
        img.src = e.target.result;
    };
    reader.readAsDataURL(file);
});
</script>
{% endblock %}
