{% extends 'base.html.twig' %}

{% block title %}Modifier mon profil — {{ app.user.username }}{% endblock %}

{% block stylesheets %}
<style>
    .edit-header {
        background: linear-gradient(135deg, #1a2e5a 0%, #2563eb 100%);
        padding: 24px 28px;
        border-radius: 12px 12px 0 0;
        color: #fff;
        display: flex; align-items: center; gap: 16px;
    }
    .edit-header .avatar {
        width: 52px; height: 52px;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; font-weight: 800; color: #fff;
        flex-shrink: 0;
    }
    .edit-header h4 { margin: 0; font-size: 1.15rem; font-weight: 800; }
    .edit-header p  { margin: 0; opacity: 0.75; font-size: 0.85rem; }
    .field-group { margin-bottom: 20px; }
    .field-group label {
        font-size: 0.82rem; font-weight: 700; color: #475569;
        text-transform: uppercase; letter-spacing: 0.4px;
        margin-bottom: 6px; display: flex; align-items: center; gap: 6px;
    }
    .field-group label i { color: #2563eb; }
    .field-group .form-control {
        border: 1.5px solid #e2e8f0;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 0.95rem;
        color: #1e293b;
        transition: .2s;
    }
    .field-group .form-control:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
        outline: none;
    }
    .btn-save {
        background: #2563eb; color: #fff; border: none;
        border-radius: 8px; padding: 11px 28px;
        font-weight: 700; font-size: 0.95rem; cursor: pointer;
        transition: .2s;
    }
    .btn-save:hover { background: #1d4ed8; }
    .btn-cancel {
        background: #f1f5f9; color: #475569; border: none;
        border-radius: 8px; padding: 11px 20px;
        font-weight: 600; font-size: 0.95rem;
        text-decoration: none; transition: .2s;
    }
    .btn-cancel:hover { background: #e2e8f0; color: #1e293b; text-decoration: none; }
</style>
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center pt-3">
        <div class="col-lg-6 col-md-8 col-12">

            <div class="card" style="border-radius:12px; overflow:hidden; box-shadow:0 4px 24px rgba(0,0,0,0.08);">

                <div class="edit-header">
                    <div class="avatar">{{ app.user.username|first|upper }}</div>
                    <div>
                        <h4>Modifier mon profil</h4>
                        <p>Les modifications seront appliquées immédiatement</p>
                    </div>
                </div>

                <div class="card-body" style="padding: 28px;">
                    <form action="" method="POST">
                        <input type="hidden" name="profile_token" value="{{ csrf_token('profile') }}">

                        <div class="field-group">
                            <label><i class="fas fa-user"></i> Nom d'utilisateur</label>
                            <input name="username" type="text" class="form-control"
                                   value="{{ app.user.username }}" required>
                        </div>

                        <div class="field-group">
                            <label><i class="fas fa-envelope"></i> Adresse email</label>
                            <input name="email" type="email" class="form-control"
                                   value="{{ app.user.email }}" placeholder="vous@exemple.com">
                        </div>

                        <div class="field-group">
                            <label><i class="fas fa-phone"></i> Téléphone</label>
                            <input name="telephone" type="tel" class="form-control"
                                   value="{{ app.user.telephone }}" placeholder="0851234567">
                        </div>

                        <div class="d-flex align-items-center" style="gap:10px; margin-top:8px;">
                            <button type="submit" class="btn-save">
                                <i class="fas fa-save mr-1"></i> Enregistrer
                            </button>
                            <a href="{{ path('app_profile') }}" class="btn-cancel">
                                Annuler
                            </a>
                        </div>
                    </form>
                </div>

            </div>

        </div>
    </div>
</div>
{% endblock %}
