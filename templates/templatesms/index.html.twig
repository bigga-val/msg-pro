{% extends 'base.html.twig' %}

{% block title %}Modèles de Messages{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-gradient-dark d-flex justify-content-between align-items-center">
                    <h3 class="card-title mb-0">Modèles de Messages</h3>
                    <a class="btn btn-success btn-sm" href="{{ path('app_templatesms_new') }}">
                        <i class="fas fa-plus"></i> Nouveau modèle
                    </a>
                </div>
                <div class="card-body">
                    <table class="table table-striped table-hover datatable">
                        <thead class="thead-dark">
                        <tr>
                            <th>#</th>
                            <th>Titre</th>
                            <th>Texte</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% set counter = 0 %}
                        {% for templatesm in templatesms %}
                            {% set counter = counter + 1 %}
                            <tr>
                                <td>{{ counter }}</td>
                                <td>{{ templatesm.titre }}</td>
                                <td>{{ templatesm.texte }}</td>
                                <td>
                                    <a href="{{ path('app_templatesms_edit', {'id': templatesm.id}) }}" class="btn btn-sm btn-primary">Modifier</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center text-muted">Aucun modèle trouvé</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
