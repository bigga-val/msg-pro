{% include("components/topbar.html.twig") %}

<aside class="main-sidebar sidebar-dark-primary elevation-4">
    <a href="{{ path('app_landing') }}" class="brand-link">
        <img src="{{ asset('msg-logo.PNG') }}" alt="MSG-PRO Logo" class="brand-image img-circle elevation-3">
        <span class="brand-text">MSG-PRO</span>
    </a>

    <div class="sidebar">
        <!-- User panel -->
        <div class="user-panel mt-3 pb-3 mb-3 d-flex align-items-center">
            <div class="image">
                <div class="sidebar-user-avatar">
                    <i class="fas fa-user"></i>
                </div>
            </div>
            <div class="info ms-2 sidebar-info">
                {% if app.user %}
                    <span class="sidebar-username">
                        {{ app.user.username | upper }}
                    </span>
                    <span class="badge badge-info">
                        <i class="fas fa-sms me-1"></i>
                        <span id="qty-sms">{{ app.user.totalSMS ?? 0 }}</span> SMS
                    </span>
                {% endif %}
            </div>
        </div>

        <nav class="mt-2">
            <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">

                <li class="nav-item">
                    <a href="{{ path('app_home') }}" class="nav-link {% if app.request.get('_route') == 'app_home' %}active{% endif %}">
                        <i class="nav-icon fas fa-tachometer-alt"></i>
                        <p>Tableau de bord</p>
                    </a>
                </li>

                <li class="nav-item">
                    <a href="{{ path('app_envoi_sms') }}" class="nav-link {% if app.request.get('_route') == 'app_envoi_sms' %}active{% endif %}">
                        <i class="nav-icon fas fa-paper-plane"></i>
                        <p>Envoyer SMS</p>
                    </a>
                </li>

                <li class="nav-item">
                    <a href="{{ path('app_templatesms_index') }}" class="nav-link {% if app.request.get('_route') starts with 'app_templatesms' %}active{% endif %}">
                        <i class="nav-icon fas fa-file-alt"></i>
                        <p>Modèles SMS</p>
                    </a>
                </li>

                <li class="nav-item">
                    <a href="{{ path('app_historique_index') }}" class="nav-link {% if app.request.get('_route') starts with 'app_historique' %}active{% endif %}">
                        <i class="nav-icon fas fa-history"></i>
                        <p>Historique</p>
                    </a>
                </li>

                <!-- Contacts -->
                <li class="nav-item">
                    <a href="#" class="nav-link">
                        <i class="nav-icon fas fa-address-book"></i>
                        <p>Contacts <i class="fas fa-angle-left right"></i></p>
                    </a>
                    <ul class="nav nav-treeview">
                        <li class="nav-item">
                            <a href="{{ path('app_contact_index') }}" class="nav-link">
                                <i class="far fa-circle nav-icon"></i>
                                <p>Mes contacts</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('app_groupe_new') }}" class="nav-link">
                                <i class="far fa-circle nav-icon"></i>
                                <p>Nouveau groupe / Import</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('app_groupe_index') }}" class="nav-link">
                                <i class="far fa-circle nav-icon"></i>
                                <p>Mes groupes</p>
                            </a>
                        </li>
                    </ul>
                </li>

                <!-- Paramètres -->
                <li class="nav-item">
                    <a href="#" class="nav-link">
                        <i class="nav-icon fas fa-cog"></i>
                        <p>Paramètres <i class="fas fa-angle-left right"></i></p>
                    </a>
                    <ul class="nav nav-treeview">
                        <li class="nav-item">
                            <a href="{{ path('app_organisation_index') }}" class="nav-link">
                                <i class="far fa-circle nav-icon"></i>
                                <p>Mes organisations</p>
                            </a>
                        </li>
                        {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a href="{{ path('app_type_organisation_index') }}" class="nav-link">
                                <i class="far fa-circle nav-icon"></i>
                                <p>Types d'organisation</p>
                            </a>
                        </li>
                        {% endif %}
                    </ul>
                </li>

                {% if app.user %}
                    <li class="nav-item">
                        <a href="{{ path('app_profile') }}" class="nav-link {% if app.request.get('_route') == 'app_profile' %}active{% endif %}">
                            <i class="nav-icon fas fa-user-circle"></i>
                            <p>Mon profil</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_documentation') }}" class="nav-link">
                            <i class="nav-icon fas fa-book"></i>
                            <p>Documentation</p>
                        </a>
                    </li>

                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item nav-admin-section">
                            <p class="nav-header">Administration</p>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('app_liste_users') }}" class="nav-link">
                                <i class="nav-icon fas fa-users"></i>
                                <p>Utilisateurs</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('app_commande_index') }}" class="nav-link">
                                <i class="nav-icon fas fa-shopping-cart"></i>
                                <p>Commandes</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('app_liste_recharges') }}" class="nav-link">
                                <i class="nav-icon fas fa-credit-card"></i>
                                <p>Recharges</p>
                            </a>
                        </li>
                    {% endif %}

                    <li class="nav-item nav-logout-item">
                        <a href="{{ path('app_logout') }}" class="nav-link">
                            <i class="nav-icon fas fa-sign-out-alt"></i>
                            <p>Déconnexion</p>
                        </a>
                    </li>
                {% endif %}

            </ul>
        </nav>
    </div>
</aside>
