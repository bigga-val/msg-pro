{% extends 'base.html.twig' %}

{% block title %}Importer des contacts — MSG-PRO{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('styles/import.css') }}">
{% endblock %}

{% block body %}
<div class="container-fluid py-3">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="import-card">

                <!-- Header -->
                <div class="import-header">
                    <div>
                        <h4><i class="fas fa-file-excel me-2"></i>Importer des contacts via Excel</h4>
                        <p>Créez un groupe et importez vos contacts en une seule opération.</p>
                    </div>
                    <a href="{{ path('app_groupe_index') }}" class="btn btn-sm btn-outline-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Retour
                    </a>
                </div>

                <!-- Step 1 : Infos groupe -->
                <div class="import-section">
                    <div class="import-step-label"><span>1</span> Informations du groupe</div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="import-label">Nom du groupe <span class="text-danger">*</span></label>
                            <input type="text" id="groupe_designation" class="form-control import-input"
                                   placeholder="ex : Clients VIP, Équipe RH…">
                        </div>
                    </div>
                </div>

                <!-- Step 2 : Upload fichier -->
                <div class="import-section">
                    <div class="import-step-label"><span>2</span> Fichier Excel</div>

                    <div class="upload-zone" id="upload-zone">
                        <i class="fas fa-cloud-upload-alt upload-icon"></i>
                        <p class="upload-text">Glissez votre fichier ici ou <label for="excelFileInput" class="upload-browse">parcourez</label></p>
                        <p class="upload-hint">Format accepté : <strong>.xlsx</strong> — colonnes : Telephone, Nom, Postnom, Adresse, Fonction</p>
                        <input type="file" id="excelFileInput" accept=".xlsx" class="d-none">
                    </div>

                    <div class="upload-template-link">
                        <i class="fas fa-download me-1"></i>
                        <a href="{{ asset('template_contacts.xlsx') }}">Télécharger le modèle Excel</a>
                    </div>
                </div>

                <!-- Step 3 : Prévisualisation -->
                <div class="import-section d-none" id="section-preview">
                    <div class="import-step-label"><span>3</span> Prévisualisation <span id="preview-count" class="preview-count"></span></div>

                    <div class="preview-table-wrap">
                        <table class="table preview-table mb-0">
                            <thead>
                                <tr>
                                    <th>Téléphone</th>
                                    <th>Nom</th>
                                    <th>Postnom</th>
                                    <th>Adresse</th>
                                    <th>Fonction</th>
                                </tr>
                            </thead>
                            <tbody id="tbody"></tbody>
                        </table>
                    </div>
                </div>

                <!-- Erreur & Actions -->
                <div class="import-footer">
                    <span id="error-msg" class="import-error"></span>
                    <div class="import-actions">
                        <div class="import-progress d-none" id="import-progress">
                            <div class="progress-bar-wrap">
                                <div class="progress-bar-fill" id="progress-fill"></div>
                            </div>
                            <span id="progress-label">Importation…</span>
                        </div>
                        <button id="btn-savexlsx" class="btn btn-primary btn-import" disabled>
                            <i class="fas fa-upload me-2"></i> Importer les contacts
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<script src="{{ asset('plugins/jquery/jquery.min.js') }}"></script>
<script src="https://unpkg.com/xlsx/dist/xlsx.full.min.js"></script>
<script>
let importData = [];

function esc(v) { return $('<span>').text(v ?? '').html(); }

// Drag & drop
const zone = document.getElementById('upload-zone');
zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
zone.addEventListener('drop', e => {
    e.preventDefault();
    zone.classList.remove('drag-over');
    const file = e.dataTransfer.files[0];
    if (file) handleFile(file);
});

$('#excelFileInput').on('change', function () {
    if (this.files[0]) handleFile(this.files[0]);
});

function handleFile(file) {
    if (!file.name.endsWith('.xlsx')) {
        showError('Seuls les fichiers .xlsx sont acceptés.');
        return;
    }
    const reader = new FileReader();
    reader.onload = function (e) {
        const workbook = XLSX.read(e.target.result, { type: 'array' });
        const worksheet = workbook.Sheets[workbook.SheetNames[0]];
        importData = XLSX.utils.sheet_to_json(worksheet);

        if (importData.length === 0) {
            showError('Le fichier est vide ou ne contient pas de données valides.');
            return;
        }

        // Afficher la prévisualisation
        let tbody = '';
        importData.forEach(row => {
            tbody += '<tr>'
                + '<td>' + esc(row['Telephone']) + '</td>'
                + '<td>' + esc(row['Nom']) + '</td>'
                + '<td>' + esc(row['Postnom']) + '</td>'
                + '<td>' + esc(row['Adresse']) + '</td>'
                + '<td>' + esc(row['Fonction']) + '</td>'
                + '</tr>';
        });
        $('#tbody').html(tbody);
        $('#preview-count').text('(' + importData.length + ' contacts)');
        $('#section-preview').removeClass('d-none');

        // Mettre à jour la zone upload
        zone.classList.add('file-loaded');
        zone.querySelector('.upload-text').innerHTML = '<i class="fas fa-check-circle me-2 text-success"></i><strong>' + file.name + '</strong>';

        $('#btn-savexlsx').prop('disabled', false);
        showError('');
    };
    reader.readAsArrayBuffer(file);
}

$('#btn-savexlsx').on('click', function () {
    const designation = $('#groupe_designation').val().trim();

    if (!designation) {
        showError('Veuillez saisir un nom de groupe.');
        $('#groupe_designation').focus();
        return;
    }
    if (importData.length === 0) {
        showError('Veuillez charger un fichier Excel.');
        return;
    }

    showError('');
    $('#btn-savexlsx').prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i> Importation…');
    $('#import-progress').removeClass('d-none');
    animateProgress();

    $.ajax({
        url: '{{ path('json_import_contacts') }}',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({
            designation: designation,
            contacts: importData
        }),
        success: function (res) {
            if (res.success) {
                $('#progress-fill').css('width', '100%');
                $('#progress-label').text(res.imported + ' contacts importés avec succès !');
                $('#btn-savexlsx').html('<i class="fas fa-check me-2"></i> Importé !').addClass('btn-success').removeClass('btn-primary');
                setTimeout(() => { window.location.href = '{{ path('app_contact_index') }}'; }, 1200);
            } else {
                showError(res.message ?? 'Une erreur est survenue.');
                resetBtn();
            }
        },
        error: function () {
            showError('Impossible d\'importer. Vérifiez votre connexion et réessayez.');
            resetBtn();
        }
    });
});

function animateProgress() {
    let w = 0;
    const iv = setInterval(() => {
        w = Math.min(w + 2, 90);
        $('#progress-fill').css('width', w + '%');
        if (w >= 90) clearInterval(iv);
    }, 40);
}

function showError(msg) {
    $('#error-msg').text(msg);
}

function resetBtn() {
    $('#btn-savexlsx').prop('disabled', false).html('<i class="fas fa-upload me-2"></i> Importer les contacts');
    $('#import-progress').addClass('d-none');
    $('#progress-fill').css('width', '0%');
}
</script>
{% endblock %}
