{% extends 'base.html.twig' %}

{% block title %}Gérer les contacts — {{ groupe.designation }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center" style="background:#fff; border-bottom:2px solid #e9ecef;">
                    <div>
                        <i class="fas fa-users text-primary mr-2"></i>
                        <span class="font-weight-bold">{{ groupe.designation }}</span>
                    </div>
                    <a href="{{ path('app_groupe_index') }}" class="btn btn-default btn-sm">
                        <i class="fas fa-arrow-left mr-1"></i> Retour
                    </a>
                </div>
            </div>

            <div class="row">
                <!-- Contacts disponibles -->
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center" style="background:#f4f6f9;">
                            <span><i class="fas fa-address-book mr-1 text-muted"></i> Contacts disponibles <span class="badge badge-secondary ml-1">{{ allcontacts|length }}</span></span>
                            <button class="btn btn-success btn-sm" id="btn-transfer">
                                Ajouter <i class="fas fa-chevron-right ml-1"></i>
                            </button>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-hover datatable mb-0">
                                <thead style="background:#f4f6f9;">
                                <tr>
                                    <th>Téléphone</th>
                                    <th>Nom</th>
                                    <th>Fonction</th>
                                    <th style="width:40px;"></th>
                                </tr>
                                </thead>
                                <tbody id="myTable1">
                                {% for contact in allcontacts %}
                                    <tr>
                                        <td>{{ contact.telephone }}</td>
                                        <td>{{ contact.nom ~ ' ' ~ contact.postnom }}</td>
                                        <td>{{ contact.fonction }}</td>
                                        <td>
                                            <input type="checkbox" name="{{ contact.contactID }}" class="check-unselected">
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-3">Aucun contact disponible</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Contacts dans le groupe -->
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center" style="background:#f4f6f9;">
                            <span><i class="fas fa-users mr-1 text-primary"></i> Dans le groupe <span class="badge badge-info ml-1">{{ contacts|length }}</span></span>
                            <a id="btn-disallocate" class="btn btn-danger btn-sm" href="#">
                                <i class="fas fa-chevron-left mr-1"></i> Retirer
                            </a>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-hover datatable mb-0">
                                <thead style="background:#f4f6f9;">
                                <tr>
                                    <th>Téléphone</th>
                                    <th>Nom</th>
                                    <th>Fonction</th>
                                    <th style="width:40px;"></th>
                                </tr>
                                </thead>
                                <tbody id="myTable2">
                                {% for contact in contacts %}
                                    <tr>
                                        <td>{{ contact.contact.telephone }}</td>
                                        <td>{{ contact.contact.nom ~ ' ' ~ contact.contact.postnom }}</td>
                                        <td>{{ contact.contact.fonction }}</td>
                                        <td>
                                            <input type="checkbox" name="{{ contact.id }}" class="check-selected">
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-3">Aucun contact dans ce groupe</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
$(document).ready(function(){
    $("#btn-transfer").on("click", function(e){
        e.preventDefault();
        $(".check-unselected:checked").each(function(){
            $.getJSON("{{ path('json_contact_attribute') }}", {contactID: $(this).attr('name'), groupeID: {{ groupe.id }} }, function(){
                window.location.reload();
            });
        });
    });

    $("#btn-disallocate").on("click", function(e){
        e.preventDefault();
        $(".check-selected:checked").each(function(){
            $.getJSON("{{ path('json_contact_disallocate') }}", {contactID: $(this).attr('name'), groupeID: {{ groupe.id }} }, function(){
                window.location.reload();
            });
        });
    });
});
</script>
{% endblock %}
