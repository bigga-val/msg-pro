{% extends 'base.html.twig' %}

{% block title %}Liste des Groupes{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/import.css') }}">
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center" style="background:#fff; border-bottom:2px solid #e9ecef;">
                    <div>
                        <i class="fas fa-layer-group text-primary mr-2"></i>
                        <span class="font-weight-bold" style="font-size:1.05rem;">Groupes de contacts</span>
                    </div>
                    <a class="btn btn-primary btn-sm" href="{{ path('app_groupe_new') }}">
                        <i class="fas fa-plus mr-1"></i> Nouveau groupe
                    </a>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover datatable mb-0">
                        <thead style="background:#f4f6f9;">
                        <tr>
                            <th style="width:40px;">#</th>
                            <th>Désignation</th>
                            <th>Contacts</th>
                            <th style="width:200px;">Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% set counter = 0 %}
                        {% for groupe in groupes %}
                            {% set counter = counter + 1 %}
                            <tr>
                                <td class="text-muted">{{ counter }}</td>
                                <td><strong>{{ groupe.designation }}</strong></td>
                                <td><span class="badge badge-info">{{ groupe.totalContact }}</span></td>
                                <td>
                                    <a href="{{ path('app_groupe_show', {'id': groupe.id}) }}" class="btn btn-sm btn-default btn-xs">
                                        <i class="fas fa-eye"></i> Voir
                                    </a>
                                    <a href="{{ path('app_groupe_attribuer', {'id': groupe.id}) }}" class="btn btn-sm btn-info btn-xs">
                                        <i class="fas fa-users"></i> Gérer
                                    </a>
                                    <a href="{{ path('app_groupe_edit', {'id': groupe.id}) }}" class="btn btn-sm btn-warning btn-xs">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">
                                    <i class="fas fa-layer-group fa-2x mb-2 d-block"></i>
                                    Aucun groupe trouvé
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
