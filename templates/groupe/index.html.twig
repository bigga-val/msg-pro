{% extends 'base.html.twig' %}

{% block title %}Liste des Groupes{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-gradient-dark d-flex justify-content-between align-items-center">
                    <h3 class="card-title mb-0">Liste des Groupes de contacts</h3>
                    <a class="btn btn-success btn-sm" href="{{ path('app_groupe_new') }}">
                        <i class="fas fa-plus"></i> Nouveau groupe
                    </a>
                </div>
                <div class="card-body">
                    <table class="table table-striped table-hover datatable">
                        <thead class="thead-dark">
                        <tr>
                            <th>#</th>
                            <th>Désignation</th>
                            <th>Total Contacts</th>
                            <th>Organisation</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% set counter = 0 %}
                        {% for groupe in groupes %}
                            {% set counter = counter + 1 %}
                            <tr>
                                <td>{{ counter }}</td>
                                <td>{{ groupe.designation }}</td>
                                <td><span class="badge badge-info">{{ groupe.totalContact }}</span></td>
                                <td>{{ groupe.organisation }}</td>
                                <td>
                                    <a href="{{ path('app_groupe_show', {'id': groupe.id}) }}" class="btn btn-sm btn-default">Détails</a>
                                    <a href="{{ path('app_groupe_edit', {'id': groupe.id}) }}" class="btn btn-sm btn-primary">Modifier</a>
                                    <a href="{{ path('app_groupe_attribuer', {'id': groupe.id}) }}" class="btn btn-sm btn-info">Gérer</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center text-muted">Aucun groupe trouvé</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
