{% extends 'base.html.twig' %}

{% block title %}Modifier le Groupe{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center" style="background:#fff; border-bottom:2px solid #e9ecef;">
                    <div>
                        <i class="fas fa-edit text-primary mr-2"></i>
                        <span class="font-weight-bold">Modifier le groupe</span>
                    </div>
                    <a href="{{ path('app_groupe_index') }}" class="btn btn-default btn-sm">
                        <i class="fas fa-arrow-left mr-1"></i> Retour
                    </a>
                </div>
                <div class="card-body">
                    {{ include('groupe/_form.html.twig', {'button_label': 'Enregistrer'}) }}
                </div>
                <div class="card-footer text-right">
                    {{ include('groupe/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
