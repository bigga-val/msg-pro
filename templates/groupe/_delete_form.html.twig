<form method="post" action="{{ path('app_groupe_delete', {'id': groupe.id}) }}" onsubmit="return confirm('Confirmer la suppression de ce groupe ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ groupe.id) }}">
    <button class="btn btn-danger btn-sm"><i class="fas fa-trash mr-1"></i> Supprimer</button>
</form>
