{% extends 'base_landing.html.twig' %}

{% block title %}Documentation — MSG-PRO | Guide complet d'utilisation{% endblock %}
{% block meta_description %}Guide complet MSG-PRO : démarrage rapide, envoi de SMS en masse, personnalisation, organisations, templates, historique et bonnes pratiques. Plateforme SMS professionnelle en RDC.{% endblock %}
{% block canonical %}https://msg-pro.com/documentation{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/landing-docs.css') }}">
{% endblock %}

{% block body %}

<header id="header" class="header fixed-top">
    <div class="topbar d-flex align-items-center">
        <div class="container d-flex justify-content-center justify-content-md-between">
            <div class="contact-info d-flex align-items-center">
                <i class="bi bi-envelope d-flex align-items-center"><a href="mailto:info@msg-pro.com">info@msg-pro.com</a></i>
                <i class="bi bi-phone d-flex align-items-center ms-4"><span>+243 851 331 051</span></i>
            </div>
            <div class="social-links d-none d-md-flex align-items-center">
                <a href="#" class="twitter"><i class="bi bi-twitter-x"></i></a>
                <a href="https://www.facebook.com/profile.php?id=61575012670787" class="facebook"><i class="bi bi-facebook"></i></a>
                <a href="#" class="instagram"><i class="bi bi-instagram"></i></a>
                <a href="https://www.linkedin.com/company/106139815" class="linkedin"><i class="bi bi-linkedin"></i></a>
            </div>
        </div>
    </div>
    <div class="branding d-flex align-items-center">
        <div class="container position-relative d-flex align-items-center justify-content-between">
            <a href="{{ path('app_landing') }}" class="logo d-flex align-items-center">
                <img src="{{ asset('msg-logo.PNG') }}" alt="MSG-PRO logo">
                <h2 class="sitename">MSG-PRO</h2>
            </a>
            <nav id="navmenu" class="navmenu">
                <ul>
                    <li><a href="{{ path('app_landing') }}">Accueil</a></li>
                    <li><a href="{{ path('app_documentation') }}" class="active">Documentation</a></li>
                    {% if app.user %}
                        <a href="{{ path('app_home') }}" class="btn btn-outline-danger btn-sm">{{ app.user.username }}</a>
                    {% else %}
                        <li><a href="{{ path('app_login') }}">Connexion</a></li>
                        <li><a href="{{ path('app_register') }}">Inscription</a></li>
                    {% endif %}
                </ul>
                <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
            </nav>
        </div>
    </div>
</header>

<main class="main">

    <!-- Hero -->
    <section class="doc-hero">
        <div class="container">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_landing') }}">Accueil</a></li>
                    <li class="breadcrumb-item active">Documentation</li>
                </ol>
            </nav>
            <h1><i class="bi bi-book me-2"></i>Documentation</h1>
            <p>Guide complet pour démarrer, configurer et tirer le meilleur de la plateforme MSG-PRO en quelques minutes.</p>
        </div>
    </section>

    <!-- Quick Start -->
    <section class="quick-start">
        <div class="container">
            <p class="qs-title">Démarrage rapide — 4 étapes pour envoyer votre premier SMS</p>
            <p class="qs-sub">Nouveau sur MSG-PRO ? Suivez ces étapes pour être opérationnel en moins de 5 minutes.</p>
            <div class="qs-steps">
                <div class="qs-step">
                    <div class="qs-icon"><i class="bi bi-person-plus-fill"></i></div>
                    <h4>1. Créer un compte</h4>
                    <p>Inscription gratuite, 5 SMS offerts immédiatement.</p>
                    <a href="{{ path('app_register') }}" class="qs-link">S'inscrire →</a>
                </div>
                <div class="qs-step">
                    <div class="qs-icon"><i class="bi bi-building"></i></div>
                    <h4>2. Créer une organisation</h4>
                    <p>Votre nom d'expéditeur affiché sur les SMS reçus.</p>
                    <a href="#organisations" class="qs-link">En savoir plus →</a>
                </div>
                <div class="qs-step">
                    <div class="qs-icon"><i class="bi bi-people-fill"></i></div>
                    <h4>3. Ajouter des contacts</h4>
                    <p>Manuellement ou via import Excel (.xlsx).</p>
                    <a href="#contacts" class="qs-link">En savoir plus →</a>
                </div>
                <div class="qs-step">
                    <div class="qs-icon"><i class="bi bi-send-fill"></i></div>
                    <h4>4. Envoyer vos SMS</h4>
                    <p>Rédigez, personnalisez et lancez votre campagne.</p>
                    <a href="#campagne" class="qs-link">En savoir plus →</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Doc layout -->
    <section class="doc-layout">
        <div class="container">
            <div class="row g-4">

                <!-- Sidebar -->
                <div class="col-lg-3 col-md-4">
                    <div class="doc-sidebar">
                        <nav class="doc-nav">
                            <div class="nav-header">Guide utilisateur</div>
                            <a href="#presentation"><i class="bi bi-info-circle"></i> Présentation</a>
                            <a href="#fonctionnalites"><i class="bi bi-grid-3x3-gap"></i> Fonctionnalités</a>
                            <a href="#tarification"><i class="bi bi-tags"></i> Tarification</a>
                            <div class="nav-divider"></div>
                            <div class="nav-header">Utilisation</div>
                            <a href="#authentification"><i class="bi bi-person-plus"></i> Inscription & Connexion</a>
                            <a href="#organisations"><i class="bi bi-building"></i> Organisations</a>
                            <a href="#contacts"><i class="bi bi-people"></i> Contacts & Groupes</a>
                            <a href="#campagne"><i class="bi bi-send"></i> Créer une campagne</a>
                            <a href="#personnalisation"><i class="bi bi-magic"></i> Personnalisation</a>
                            <a href="#templates"><i class="bi bi-file-text"></i> Templates SMS</a>
                            <a href="#historique"><i class="bi bi-clock-history"></i> Historique & Statuts</a>
                            <div class="nav-divider"></div>
                            <div class="nav-header">Référence</div>
                            <a href="#bonnes-pratiques"><i class="bi bi-star"></i> Bonnes pratiques</a>
                            <a href="#support"><i class="bi bi-headset"></i> Support</a>
                            <a href="#confidentialite"><i class="bi bi-shield-check"></i> Sécurité</a>
                            <a href="#faq"><i class="bi bi-question-circle"></i> FAQ</a>
                        </nav>
                    </div>
                </div>

                <!-- Content -->
                <div class="col-lg-9 col-md-8">
                    <article class="doc-content">

                        <!-- Présentation -->
                        <div class="doc-section" id="presentation">
                            <h2><span class="sec-icon"><i class="bi bi-info-circle"></i></span>Présentation</h2>
                            <p><strong>MSG-PRO</strong> est une plateforme d'envoi de SMS en masse conçue pour les entreprises, associations et particuliers en <strong>République Démocratique du Congo</strong>. Elle permet de créer et gérer des campagnes SMS ciblées avec une interface simple, sans aucune compétence technique.</p>
                            <p>Compatible avec tous les réseaux nationaux — <strong>Vodacom, Airtel, Orange et Africell</strong> — vos messages atteignent vos destinataires rapidement et de façon fiable.</p>
                            <div class="callout callout-tip">
                                <i class="bi bi-gift-fill"></i>
                                <div><strong>Offre de bienvenue :</strong> 5 SMS sont crédités automatiquement à la création de votre compte, sans aucune carte bancaire requise.</div>
                            </div>
                        </div>

                        <!-- Fonctionnalités -->
                        <div class="doc-section" id="fonctionnalites">
                            <h2><span class="sec-icon"><i class="bi bi-grid-3x3-gap"></i></span>Fonctionnalités principales</h2>
                            <ul>
                                <li><strong>Campagnes SMS personnalisées :</strong> rédigez des messages adaptés à votre audience avec des variables dynamiques.</li>
                                <li><strong>Tableau de bord intuitif :</strong> suivez en temps réel l'état de vos campagnes et votre solde de crédits.</li>
                                <li><strong>Crédits SMS sans expiration :</strong> utilisez-les à votre rythme, ils ne périment jamais.</li>
                                <li><strong>Gestion des organisations :</strong> définissez vos noms d'expéditeurs personnalisés.</li>
                                <li><strong>Segmentation des contacts :</strong> organisez vos contacts en groupes thématiques.</li>
                                <li><strong>Importation Excel :</strong> ajoutez vos contacts en masse via fichier <code>.xlsx</code>.</li>
                                <li><strong>Templates de messages :</strong> sauvegardez vos messages réutilisables.</li>
                                <li><strong>Historique complet :</strong> consultez toutes vos campagnes passées et leurs statuts de livraison.</li>
                                <li><strong>Support client 24h/7j :</strong> assistance par WhatsApp et email.</li>
                            </ul>
                        </div>

                        <!-- Tarification -->
                        <div class="doc-section" id="tarification">
                            <h2><span class="sec-icon"><i class="bi bi-tags"></i></span>Tarification</h2>
                            <p>Un tarif unique et transparent : <strong>0,06 $ par SMS</strong>, sans frais cachés ni abonnement mensuel.</p>
                            <table class="doc-table">
                                <thead>
                                    <tr>
                                        <th>Pack</th>
                                        <th class="text-center">Prix</th>
                                        <th class="text-center">SMS inclus</th>
                                        <th class="text-center">Prix / SMS</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Pack Mini</td>
                                        <td class="text-center">$ 6</td>
                                        <td class="text-center">100 SMS</td>
                                        <td class="text-center">$ 0,06</td>
                                    </tr>
                                    <tr class="featured">
                                        <td>Pack Midi ⭐ Le plus populaire</td>
                                        <td class="text-center">$ 30</td>
                                        <td class="text-center">500 SMS</td>
                                        <td class="text-center">$ 0,06</td>
                                    </tr>
                                    <tr>
                                        <td>Pack Maxi</td>
                                        <td class="text-center">$ 150</td>
                                        <td class="text-center">2 500 SMS</td>
                                        <td class="text-center">$ 0,06</td>
                                    </tr>
                                    <tr>
                                        <td>Pack Personnalisé</td>
                                        <td class="text-center">Variable</td>
                                        <td class="text-center">Sur mesure</td>
                                        <td class="text-center">
                                            <a class="btn btn-sm btn-outline-primary" href="{{ path('app_commande') }}">Configurer</a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="callout callout-info">
                                <i class="bi bi-infinity"></i>
                                <div>Les crédits achetés sont <strong>valables à vie</strong>. Vous ne perdez jamais vos SMS non utilisés.</div>
                            </div>
                        </div>

                        <!-- Inscription & Connexion -->
                        <div class="doc-section" id="authentification">
                            <h2><span class="sec-icon"><i class="bi bi-person-plus"></i></span>Inscription & Connexion</h2>
                            <h3>Créer un compte</h3>
                            <ul class="step-list">
                                <li><span class="step-num">1</span><span>Rendez-vous sur <a href="{{ path('app_register') }}">la page d'inscription</a>.</span></li>
                                <li><span class="step-num">2</span><span>Remplissez le formulaire : nom d'utilisateur, téléphone, email et mot de passe.</span></li>
                                <li><span class="step-num">3</span><span>Validez — <strong>5 SMS offerts</strong> sont crédités automatiquement.</span></li>
                            </ul>
                            <h3>Se connecter</h3>
                            <ul class="step-list">
                                <li><span class="step-num">1</span><span>Rendez-vous sur <a href="{{ path('app_login') }}">la page de connexion</a>.</span></li>
                                <li><span class="step-num">2</span><span>Saisissez votre email et votre mot de passe.</span></li>
                                <li><span class="step-num">3</span><span>Accédez à votre tableau de bord.</span></li>
                            </ul>
                            <div class="callout callout-warning">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                                <div><strong>Mot de passe oublié ?</strong> Utilisez la fonction de réinitialisation sur la page de connexion ou contactez le support.</div>
                            </div>
                        </div>

                        <!-- Organisations -->
                        <div class="doc-section" id="organisations">
                            <h2><span class="sec-icon"><i class="bi bi-building"></i></span>Organisations (Expéditeurs)</h2>
                            <p>Une <strong>organisation</strong> correspond au nom qui s'affichera comme expéditeur sur les SMS reçus par vos destinataires. C'est une étape <strong>obligatoire</strong> avant de pouvoir envoyer des SMS.</p>
                            <div class="callout callout-warning">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                                <div><strong>Important :</strong> sans organisation créée et approuvée, vos SMS partent avec l'expéditeur générique <code>insoft</code>. Créez votre organisation dès la première connexion.</div>
                            </div>
                            <h3>Créer une organisation</h3>
                            <ul class="step-list">
                                <li><span class="step-num">1</span><span>Dans le menu, cliquez sur <strong>"Organisations"</strong>.</span></li>
                                <li><span class="step-num">2</span><span>Cliquez sur <strong>"Nouvelle organisation"</strong> et renseignez la désignation (ex: <code>MonEntreprise</code>).</span></li>
                                <li><span class="step-num">3</span><span>Soumettez — votre organisation sera vérifiée et approuvée par l'administrateur.</span></li>
                                <li><span class="step-num">4</span><span>Une fois approuvée, sélectionnez-la comme expéditeur lors de vos envois.</span></li>
                            </ul>
                            <div class="callout callout-info">
                                <i class="bi bi-info-circle-fill"></i>
                                <div>Le nom d'expéditeur est limité à <strong>11 caractères</strong> alphanumériques (sans espaces ni caractères spéciaux). Ex : <code>MSGPRO</code>, <code>MonShop</code>.</div>
                            </div>
                        </div>

                        <!-- Contacts -->
                        <div class="doc-section" id="contacts">
                            <h2><span class="sec-icon"><i class="bi bi-people"></i></span>Contacts & Groupes</h2>
                            <h3>Ajouter des contacts</h3>
                            <ul>
                                <li><strong>Ajout manuel :</strong> depuis le menu "Contacts", cliquez sur "Nouveau contact" et renseignez les champs.</li>
                                <li><strong>Importation Excel :</strong> préparez un fichier <code>.xlsx</code> avec les colonnes Nom, Postnom, Téléphone, Email, Adresse, Fonction — puis importez-le en masse.</li>
                            </ul>
                            <div class="callout callout-tip">
                                <i class="bi bi-lightbulb-fill"></i>
                                <div><strong>Format des numéros :</strong> saisissez les numéros au format local (ex: <code>0851234567</code>). La plateforme ajoute automatiquement l'indicatif +243.</div>
                            </div>
                            <h3>Créer et gérer des groupes</h3>
                            <p>Les groupes permettent de segmenter vos contacts pour des envois ciblés :</p>
                            <ul class="step-list">
                                <li><span class="step-num">1</span><span>Dans le menu, cliquez sur <strong>"Groupes"</strong> → <strong>"Nouveau groupe"</strong>.</span></li>
                                <li><span class="step-num">2</span><span>Donnez un nom au groupe (ex: <em>Clients VIP</em>, <em>Équipe RH</em>).</span></li>
                                <li><span class="step-num">3</span><span>Attribuez des contacts à ce groupe depuis la fiche de chaque contact.</span></li>
                                <li><span class="step-num">4</span><span>Lors d'un envoi, sélectionnez ce groupe comme liste cible.</span></li>
                            </ul>
                        </div>

                        <!-- Campagne -->
                        <div class="doc-section" id="campagne">
                            <h2><span class="sec-icon"><i class="bi bi-send"></i></span>Créer une campagne SMS</h2>
                            <ul class="step-list">
                                <li><span class="step-num">1</span><span>Dans le menu, cliquez sur <strong>"Envoi SMS"</strong>.</span></li>
                                <li><span class="step-num">2</span><span>Sélectionnez votre <strong>organisation</strong> (expéditeur) dans la liste déroulante.</span></li>
                                <li><span class="step-num">3</span><span>Choisissez le <strong>groupe de contacts</strong> destinataire.</span></li>
                                <li><span class="step-num">4</span><span>Rédigez votre message. Utilisez les <a href="#personnalisation">variables de personnalisation</a> si besoin.</span></li>
                                <li><span class="step-num">5</span><span>Cliquez sur <strong>"Envoyer"</strong> — les SMS sont transmis en temps réel sur tous les réseaux.</span></li>
                            </ul>
                            <div class="callout callout-warning">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                                <div><strong>Vérifiez votre solde</strong> avant l'envoi. Le nombre de SMS disponibles doit être supérieur ou égal au nombre de contacts dans le groupe sélectionné.</div>
                            </div>
                        </div>

                        <!-- Personnalisation -->
                        <div class="doc-section" id="personnalisation">
                            <h2><span class="sec-icon"><i class="bi bi-magic"></i></span>Personnalisation des messages</h2>
                            <p>Rendez vos SMS plus percutants en insérant les données de chaque contact directement dans le texte. Les <strong>variables</strong> sont remplacées automatiquement à l'envoi.</p>
                            <h3>Variables disponibles</h3>
                            <div class="tags-grid">
                                <span class="tag-badge">[Nom]</span>
                                <span class="tag-badge">[Postnom]</span>
                                <span class="tag-badge">[Adresse]</span>
                                <span class="tag-badge">[Fonction]</span>
                            </div>
                            <h3>Exemple concret</h3>
                            <div class="sms-example">
                                <div class="sms-bubble before">
                                    <div class="sms-label">✏️ Message rédigé</div>
                                    Bonjour <code>[Nom]</code> <code>[Postnom]</code>, votre commande est prête. Merci de passer la récupérer au magasin. — MonShop
                                </div>
                                <div class="sms-bubble after">
                                    <div class="sms-label">✅ SMS reçu par Jean Kabila</div>
                                    Bonjour Jean Kabila, votre commande est prête. Merci de passer la récupérer au magasin. — MonShop
                                </div>
                            </div>
                            <div class="callout callout-tip">
                                <i class="bi bi-lightbulb-fill"></i>
                                <div>Si un contact n'a pas de valeur pour une variable (ex: Postnom vide), la variable est remplacée par une chaîne vide. Assurez-vous que vos contacts ont les champs renseignés.</div>
                            </div>
                        </div>

                        <!-- Templates -->
                        <div class="doc-section" id="templates">
                            <h2><span class="sec-icon"><i class="bi bi-file-text"></i></span>Templates SMS</h2>
                            <p>Les <strong>templates</strong> sont des modèles de messages que vous sauvegardez pour les réutiliser facilement lors de vos campagnes, sans avoir à réécrire le texte à chaque fois.</p>
                            <h3>Créer un template</h3>
                            <ul class="step-list">
                                <li><span class="step-num">1</span><span>Depuis la page d'envoi, rédigez votre message dans la zone de texte.</span></li>
                                <li><span class="step-num">2</span><span>Donnez un titre au template (ex: <em>Promo du mois</em>, <em>Rappel RDV</em>).</span></li>
                                <li><span class="step-num">3</span><span>Cliquez sur <strong>"Sauvegarder comme template"</strong>.</span></li>
                            </ul>
                            <h3>Utiliser un template</h3>
                            <p>Lors d'un envoi, sélectionnez un template existant dans la liste — le texte se charge automatiquement dans la zone de message. Vous pouvez l'utiliser tel quel ou le modifier.</p>
                            <div class="callout callout-tip">
                                <i class="bi bi-lightbulb-fill"></i>
                                <div>Les variables de personnalisation (<code>[Nom]</code>, <code>[Postnom]</code>…) sont pleinement supportées dans les templates.</div>
                            </div>
                        </div>

                        <!-- Historique & Statuts -->
                        <div class="doc-section" id="historique">
                            <h2><span class="sec-icon"><i class="bi bi-clock-history"></i></span>Historique & Statuts de livraison</h2>
                            <p>L'historique enregistre chaque SMS envoyé avec son expéditeur, le destinataire, le message, la date et le <strong>statut de livraison</strong>.</p>
                            <h3>Signification des statuts</h3>
                            <table class="status-table">
                                <thead>
                                    <tr><th>Code</th><th>Statut</th><th>Signification</th></tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><code>0</code></td>
                                        <td><span class="badge-success">Succès</span></td>
                                        <td>Le SMS a été accepté et transmis au réseau de l'opérateur.</td>
                                    </tr>
                                    <tr>
                                        <td><code>2</code></td>
                                        <td><span class="badge-pending">En attente</span></td>
                                        <td>Le SMS est en cours de transmission. Le réseau est temporairement indisponible.</td>
                                    </tr>
                                    <tr>
                                        <td><code>-1</code></td>
                                        <td><span class="badge-error">Échec</span></td>
                                        <td>Numéro invalide, hors réseau ou crédit insuffisant. Vérifiez le numéro et votre solde.</td>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="callout callout-info">
                                <i class="bi bi-info-circle-fill"></i>
                                <div>Un SMS avec statut <strong>Succès</strong> a bien quitté notre plateforme. La livraison finale dépend de la disponibilité du réseau de l'opérateur côté destinataire.</div>
                            </div>
                        </div>

                        <!-- Bonnes pratiques -->
                        <div class="doc-section" id="bonnes-pratiques">
                            <h2><span class="sec-icon"><i class="bi bi-star"></i></span>Bonnes pratiques SMS</h2>
                            <p>Pour maximiser l'impact de vos campagnes et respecter vos destinataires :</p>
                            <div class="bp-grid">
                                <div class="bp-card">
                                    <i class="bi bi-fonts"></i>
                                    <h4>Soyez concis</h4>
                                    <p>Un SMS = 160 caractères. Au-delà, il est découpé en plusieurs parties. Allez droit au but.</p>
                                </div>
                                <div class="bp-card">
                                    <i class="bi bi-clock"></i>
                                    <h4>Choisissez le bon moment</h4>
                                    <p>Envoyez entre 8h et 19h en semaine. Évitez les dimanches matin et les jours fériés.</p>
                                </div>
                                <div class="bp-card">
                                    <i class="bi bi-person-check"></i>
                                    <h4>Identifiez-vous clairement</h4>
                                    <p>Utilisez un nom d'expéditeur reconnaissable. Les SMS sans expéditeur identifiable sont ignorés.</p>
                                </div>
                                <div class="bp-card">
                                    <i class="bi bi-bullseye"></i>
                                    <h4>Segmentez vos envois</h4>
                                    <p>Un message ciblé par groupe est plus efficace qu'un envoi général à tous vos contacts.</p>
                                </div>
                                <div class="bp-card">
                                    <i class="bi bi-shield-check"></i>
                                    <h4>Respectez la vie privée</h4>
                                    <p>N'envoyez des SMS qu'aux personnes ayant consenti à recevoir vos communications.</p>
                                </div>
                                <div class="bp-card">
                                    <i class="bi bi-bar-chart-line"></i>
                                    <h4>Suivez vos résultats</h4>
                                    <p>Consultez l'historique après chaque campagne pour identifier les numéros en échec et nettoyer votre liste.</p>
                                </div>
                            </div>
                        </div>

                        <!-- Support -->
                        <div class="doc-section" id="support">
                            <h2><span class="sec-icon"><i class="bi bi-headset"></i></span>Support et assistance</h2>
                            <p>Notre équipe est disponible <strong>24h/7j</strong> pour vous accompagner :</p>
