{% extends 'base_landing.html.twig' %}

{% block title %}Documentation — MSG-PRO | Guide complet d'utilisation{% endblock %}
{% block meta_description %}Guide complet MSG-PRO : démarrage rapide, envoi de SMS en masse, personnalisation, organisations, templates, historique et bonnes pratiques. Plateforme SMS professionnelle en RDC.{% endblock %}
{% block canonical %}https://msg-pro.com/documentation{% endblock %}

{% block stylesheets %}
<style>
/* ========== PALETTE ========== */
:root { --accent-color: #2563eb; --nav-hover-color: #2563eb; }
.header { --background-color: #1a2e5a; }
.dark-background { --background-color: #1a2e5a; }

/* ========== DOC HERO ========== */
.doc-hero {
    background: linear-gradient(135deg, #1a2e5a 0%, #2563eb 100%);
    padding: 100px 0 60px;
    color: #fff;
    margin-top: 90px;
}
.doc-hero h1 { font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 800; margin-bottom: 12px; }
.doc-hero p { font-size: 1.05rem; color: rgba(255,255,255,0.8); max-width: 600px; margin-bottom: 0; }
.doc-hero .breadcrumb { background: transparent; padding: 0; margin-bottom: 16px; font-size: 0.85rem; }
.doc-hero .breadcrumb-item a { color: rgba(255,255,255,0.65); text-decoration: none; }
.doc-hero .breadcrumb-item.active { color: rgba(255,255,255,0.9); }
.doc-hero .breadcrumb-item + .breadcrumb-item::before { color: rgba(255,255,255,0.4); }

/* ========== QUICK START ========== */
.quick-start {
    background: #fff;
    border-bottom: 1px solid #e2e8f0;
    padding: 52px 0;
}
.quick-start .qs-title {
    text-align: center;
    font-size: 1.4rem;
    font-weight: 800;
    color: #1a2e5a;
    margin-bottom: 8px;
}
.quick-start .qs-sub {
    text-align: center;
    color: #64748b;
    font-size: 0.95rem;
    margin-bottom: 40px;
}
.qs-steps {
    display: flex;
    gap: 0;
    position: relative;
    align-items: flex-start;
}
.qs-steps::before {
    content: '';
    position: absolute;
    top: 28px;
    left: calc(12.5% + 14px);
    right: calc(12.5% + 14px);
    height: 2px;
    background: #bfdbfe;
    z-index: 0;
}
.qs-step {
    flex: 1;
    text-align: center;
    padding: 0 12px;
    position: relative;
    z-index: 1;
}
.qs-step .qs-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--accent-color);
    color: #fff;
    font-size: 1.3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 14px;
    box-shadow: 0 4px 16px rgba(37,99,235,0.3);
    border: 3px solid #fff;
}
.qs-step h4 { font-size: 0.93rem; font-weight: 700; color: #1e293b; margin-bottom: 6px; }
.qs-step p { font-size: 0.83rem; color: #64748b; margin: 0; line-height: 1.5; }
.qs-step a.qs-link {
    display: inline-block;
    margin-top: 10px;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--accent-color);
    text-decoration: none;
    border: 1.5px solid #bfdbfe;
    border-radius: 20px;
    padding: 3px 12px;
    background: #eff6ff;
    transition: 0.2s;
}
.qs-step a.qs-link:hover { background: var(--accent-color); color: #fff; border-color: var(--accent-color); }

/* ========== DOC LAYOUT ========== */
.doc-layout { padding: 60px 0 80px; background: #f8fafc; }

/* Sidebar */
.doc-sidebar { position: sticky; top: 100px; }
.doc-nav {
    background: #fff;
    border-radius: 14px;
    border: 1px solid #e2e8f0;
    padding: 24px 0;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
}
.doc-nav .nav-header {
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 1px; color: #94a3b8; padding: 0 24px 10px;
}
.doc-nav a {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 24px; font-size: 0.88rem; color: #475569;
    text-decoration: none; border-left: 3px solid transparent;
    transition: 0.2s; font-weight: 500;
}
.doc-nav a:hover, .doc-nav a.active {
    color: var(--accent-color); background: #eff6ff; border-left-color: var(--accent-color);
}
.doc-nav a i { font-size: 0.85rem; flex-shrink: 0; color: #94a3b8; }
.doc-nav a:hover i, .doc-nav a.active i { color: var(--accent-color); }
.doc-nav .nav-divider { height: 1px; background: #f1f5f9; margin: 8px 0; }

/* Content */
.doc-content {
    background: #fff; border-radius: 14px; border: 1px solid #e2e8f0;
    padding: 44px 48px; box-shadow: 0 2px 12px rgba(0,0,0,0.05);
}
.doc-section { padding-top: 20px; padding-bottom: 36px; border-bottom: 1px solid #f1f5f9; }
.doc-section:last-child { border-bottom: none; padding-bottom: 0; }
.doc-section h2 {
    font-size: 1.3rem; font-weight: 800; color: #1a2e5a; margin-bottom: 14px;
    display: flex; align-items: center; gap: 10px;
}
.doc-section h2 .sec-icon {
    background: #eff6ff; color: var(--accent-color);
    width: 36px; height: 36px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; flex-shrink: 0;
}
.doc-section h3 { font-size: 1rem; font-weight: 700; color: #1e293b; margin: 20px 0 10px; }
.doc-section p, .doc-section li { color: #475569; font-size: 0.94rem; line-height: 1.75; }
.doc-section ul, .doc-section ol { padding-left: 20px; margin-bottom: 0; }
.doc-section li { margin-bottom: 6px; }
.doc-section strong { color: #1e293b; }
.doc-section code {
    background: #f1f5f9; color: #2563eb; padding: 1px 6px;
    border-radius: 4px; font-size: 0.88em; font-family: monospace;
}

/* Callouts */
.callout {
    border-radius: 10px; padding: 14px 18px; margin: 16px 0;
    display: flex; gap: 12px; align-items: flex-start; font-size: 0.9rem;
}
.callout i { font-size: 1.1rem; flex-shrink: 0; margin-top: 1px; }
.callout-tip { background: #f0fdf4; border: 1px solid #86efac; color: #166534; }
.callout-tip i { color: #16a34a; }
.callout-warning { background: #fffbeb; border: 1px solid #fcd34d; color: #92400e; }
.callout-warning i { color: #d97706; }
.callout-info { background: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af; }
.callout-info i { color: #2563eb; }

/* Step list */
.step-list { list-style: none; padding: 0; margin: 0; }
.step-list li { display: flex; gap: 14px; margin-bottom: 14px; align-items: flex-start; }
.step-list li .step-num {
    background: var(--accent-color); color: #fff; width: 26px; height: 26px;
    border-radius: 50%; font-size: 0.78rem; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-top: 2px;
}

/* Pricing table */
.doc-table { width: 100%; border-collapse: separate; border-spacing: 0; margin: 16px 0; font-size: 0.9rem; }
.doc-table thead th {
    background: #1a2e5a; color: #fff; padding: 11px 16px;
    font-weight: 600; letter-spacing: 0.3px;
}
.doc-table thead th:first-child { border-radius: 8px 0 0 0; }
.doc-table thead th:last-child  { border-radius: 0 8px 0 0; }
.doc-table tbody td { padding: 10px 16px; border-bottom: 1px solid #f1f5f9; color: #475569; }
.doc-table tbody tr:last-child td { border-bottom: none; }
.doc-table tbody tr:hover td { background: #f8fafc; }
.doc-table tbody tr.featured td { background: #eff6ff; color: #1e3a8a; font-weight: 600; }

/* Personalization example */
.sms-example {
    display: flex; gap: 20px; margin: 16px 0; flex-wrap: wrap;
}
.sms-bubble {
    flex: 1; min-width: 220px; border-radius: 12px; padding: 16px 18px;
    font-size: 0.88rem; line-height: 1.65;
}
.sms-bubble.before {
    background: #f1f5f9; border: 1px solid #e2e8f0; color: #475569;
}
.sms-bubble.after {
    background: #f0fdf4; border: 1px solid #86efac; color: #14532d;
}
.sms-bubble .sms-label {
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 1px; margin-bottom: 8px; opacity: 0.65;
}
.sms-bubble code { background: rgba(0,0,0,0.07); color: inherit; }

/* Tags reference */
.tags-grid { display: flex; flex-wrap: wrap; gap: 8px; margin: 12px 0; }
.tag-badge {
    background: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af;
    border-radius: 6px; padding: 5px 12px; font-size: 0.85rem;
    font-family: monospace; font-weight: 600;
}

/* Status codes */
.status-table { width: 100%; font-size: 0.9rem; border-collapse: collapse; margin-top: 12px; }
.status-table th { background: #f8fafc; color: #475569; padding: 9px 14px; text-align: left; font-weight: 700; border-bottom: 2px solid #e2e8f0; }
.status-table td { padding: 9px 14px; border-bottom: 1px solid #f1f5f9; color: #475569; }
.status-table tr:last-child td { border-bottom: none; }
.badge-success { background: #dcfce7; color: #166534; padding: 2px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: 700; }
.badge-pending { background: #fef9c3; color: #854d0e; padding: 2px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: 700; }
.badge-error   { background: #fee2e2; color: #991b1b; padding: 2px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: 700; }

/* Best practices cards */
.bp-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; margin-top: 16px; }
.bp-card {
    background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px;
    padding: 18px; font-size: 0.88rem;
}
.bp-card i { font-size: 1.4rem; color: var(--accent-color); display: block; margin-bottom: 10px; }
.bp-card h4 { font-size: 0.9rem; font-weight: 700; color: #1e293b; margin-bottom: 6px; }
.bp-card p { color: #64748b; margin: 0; line-height: 1.55; }

/* FAQ */
.faq-item { border: 1px solid #e2e8f0; border-radius: 10px; margin-bottom: 10px; overflow: hidden; }
.faq-item .faq-q {
    padding: 14px 18px; font-weight: 700; color: #1e293b;
    font-size: 0.93rem; background: #f8fafc; cursor: default;
}
.faq-item .faq-a {
    padding: 12px 18px 14px; color: #475569; font-size: 0.91rem;
    line-height: 1.65; border-top: 1px solid #e2e8f0;
}

/* Contact card */
.contact-card {
    display: flex; align-items: center; gap: 14px;
    background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px;
    padding: 14px 18px; margin-bottom: 10px; font-size: 0.92rem; color: #475569;
}
.contact-card i { font-size: 1.3rem; color: var(--accent-color); flex-shrink: 0; }
.contact-card a { color: var(--accent-color); text-decoration: none; font-weight: 600; }
.contact-card a:hover { text-decoration: underline; }

/* CTA */
.doc-cta {
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border: 1px solid #bfdbfe; border-radius: 12px;
    padding: 28px 32px; text-align: center; margin-top: 8px;
}
.doc-cta h3 { font-size: 1.15rem; font-weight: 800; color: #1e3a8a; margin-bottom: 8px; }
.doc-cta p { color: #3b5bdb; font-size: 0.92rem; margin-bottom: 16px; }
.doc-cta .btn-doc {
    background: var(--accent-color); color: #fff; padding: 11px 28px;
    border-radius: 8px; font-weight: 700; font-size: 0.93rem;
    text-decoration: none; display: inline-block; transition: 0.25s;
}
.doc-cta .btn-doc:hover { background: #1d4ed8; color: #fff; }

@media (max-width: 767px) {
    .doc-content { padding: 28px 20px; }
    .doc-sidebar { position: static; margin-bottom: 24px; }
    .qs-steps { flex-direction: column; align-items: center; }
    .qs-steps::before { display: none; }
    .qs-step { width: 100%; max-width: 320px; padding-bottom: 20px; }
    .sms-example { flex-direction: column; }
}
</style>
{% endblock %}

{% block body %}

<header id="header" class="header fixed-top">
    <div class="topbar d-flex align-items-center">
        <div class="container d-flex justify-content-center justify-content-md-between">
            <div class="contact-info d-flex align-items-center">
                <i class="bi bi-envelope d-flex align-items-center"><a href="mailto:info@msg-pro.com">info@msg-pro.com</a></i>
                <i class="bi bi-phone d-flex align-items-center ms-4"><span>+243 851 331 051</span></i>
            </div>
            <div class="social-links d-none d-md-flex align-items-center">
                <a href="#" class="twitter"><i class="bi bi-twitter-x"></i></a>
                <a href="https://www.facebook.com/profile.php?id=61575012670787" class="facebook"><i class="bi bi-facebook"></i></a>
                <a href="#" class="instagram"><i class="bi bi-instagram"></i></a>
                <a href="https://www.linkedin.com/company/106139815" class="linkedin"><i class="bi bi-linkedin"></i></a>
            </div>
        </div>
    </div>
    <div class="branding d-flex align-items-center">
        <div class="container position-relative d-flex align-items-center justify-content-between">
            <a href="{{ path('app_landing') }}" class="logo d-flex align-items-center">
                <img src="{{ asset('msg-logo.PNG') }}" alt="MSG-PRO logo">
                <h2 class="sitename">MSG-PRO</h2>
            </a>
            <nav id="navmenu" class="navmenu">
                <ul>
                    <li><a href="{{ path('app_landing') }}">Accueil</a></li>
                    <li><a href="{{ path('app_documentation') }}" class="active">Documentation</a></li>
                    {% if app.user %}
                        <a href="{{ path('app_home') }}" class="btn btn-outline-danger btn-sm">{{ app.user.username }}</a>
                    {% else %}
                        <li><a href="{{ path('app_login') }}">Connexion</a></li>
                        <li><a href="{{ path('app_register') }}">Inscription</a></li>
                    {% endif %}
                </ul>
                <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
            </nav>
        </div>
    </div>
</header>

<main class="main">

    <!-- Hero -->
    <section class="doc-hero">
        <div class="container">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_landing') }}">Accueil</a></li>
                    <li class="breadcrumb-item active">Documentation</li>
                </ol>
            </nav>
            <h1><i class="bi bi-book me-2"></i>Documentation</h1>
            <p>Guide complet pour démarrer, configurer et tirer le meilleur de la plateforme MSG-PRO en quelques minutes.</p>
        </div>
    </section>

    <!-- Quick Start -->
    <section class="quick-start">
        <div class="container">
            <p class="qs-title">Démarrage rapide — 4 étapes pour envoyer votre premier SMS</p>
            <p class="qs-sub">Nouveau sur MSG-PRO ? Suivez ces étapes pour être opérationnel en moins de 5 minutes.</p>
            <div class="qs-steps">
                <div class="qs-step">
                    <div class="qs-icon"><i class="bi bi-person-plus-fill"></i></div>
                    <h4>1. Créer un compte</h4>
                    <p>Inscription gratuite, 5 SMS offerts immédiatement.</p>
                    <a href="{{ path('app_register') }}" class="qs-link">S'inscrire →</a>
                </div>
                <div class="qs-step">
                    <div class="qs-icon"><i class="bi bi-building"></i></div>
                    <h4>2. Créer une organisation</h4>
                    <p>Votre nom d'expéditeur affiché sur les SMS reçus.</p>
                    <a href="#organisations" class="qs-link">En savoir plus →</a>
                </div>
                <div class="qs-step">
                    <div class="qs-icon"><i class="bi bi-people-fill"></i></div>
                    <h4>3. Ajouter des contacts</h4>
                    <p>Manuellement ou via import Excel (.xlsx).</p>
                    <a href="#contacts" class="qs-link">En savoir plus →</a>
                </div>
                <div class="qs-step">
                    <div class="qs-icon"><i class="bi bi-send-fill"></i></div>
                    <h4>4. Envoyer vos SMS</h4>
                    <p>Rédigez, personnalisez et lancez votre campagne.</p>
                    <a href="#campagne" class="qs-link">En savoir plus →</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Doc layout -->
    <section class="doc-layout">
        <div class="container">
            <div class="row g-4">

                <!-- Sidebar -->
                <div class="col-lg-3 col-md-4">
                    <div class="doc-sidebar">
                        <nav class="doc-nav">
                            <div class="nav-header">Guide utilisateur</div>
                            <a href="#presentation"><i class="bi bi-info-circle"></i> Présentation</a>
                            <a href="#fonctionnalites"><i class="bi bi-grid-3x3-gap"></i> Fonctionnalités</a>
                            <a href="#tarification"><i class="bi bi-tags"></i> Tarification</a>
                            <div class="nav-divider"></div>
                            <div class="nav-header">Utilisation</div>
                            <a href="#authentification"><i class="bi bi-person-plus"></i> Inscription & Connexion</a>
                            <a href="#organisations"><i class="bi bi-building"></i> Organisations</a>
                            <a href="#contacts"><i class="bi bi-people"></i> Contacts & Groupes</a>
                            <a href="#campagne"><i class="bi bi-send"></i> Créer une campagne</a>
                            <a href="#personnalisation"><i class="bi bi-magic"></i> Personnalisation</a>
                            <a href="#templates"><i class="bi bi-file-text"></i> Templates SMS</a>
                            <a href="#historique"><i class="bi bi-clock-history"></i> Historique & Statuts</a>
                            <div class="nav-divider"></div>
                            <div class="nav-header">Référence</div>
                            <a href="#bonnes-pratiques"><i class="bi bi-star"></i> Bonnes pratiques</a>
                            <a href="#support"><i class="bi bi-headset"></i> Support</a>
                            <a href="#confidentialite"><i class="bi bi-shield-check"></i> Sécurité</a>
                            <a href="#faq"><i class="bi bi-question-circle"></i> FAQ</a>
                        </nav>
                    </div>
                </div>

                <!-- Content -->
                <div class="col-lg-9 col-md-8">
                    <article class="doc-content">

                        <!-- Présentation -->
                        <div class="doc-section" id="presentation">
                            <h2><span class="sec-icon"><i class="bi bi-info-circle"></i></span>Présentation</h2>
                            <p><strong>MSG-PRO</strong> est une plateforme d'envoi de SMS en masse conçue pour les entreprises, associations et particuliers en <strong>République Démocratique du Congo</strong>. Elle permet de créer et gérer des campagnes SMS ciblées avec une interface simple, sans aucune compétence technique.</p>
                            <p>Compatible avec tous les réseaux nationaux — <strong>Vodacom, Airtel, Orange et Africell</strong> — vos messages atteignent vos destinataires rapidement et de façon fiable.</p>
                            <div class="callout callout-tip">
                                <i class="bi bi-gift-fill"></i>
                                <div><strong>Offre de bienvenue :</strong> 5 SMS sont crédités automatiquement à la création de votre compte, sans aucune carte bancaire requise.</div>
                            </div>
                        </div>

                        <!-- Fonctionnalités -->
                        <div class="doc-section" id="fonctionnalites">
                            <h2><span class="sec-icon"><i class="bi bi-grid-3x3-gap"></i></span>Fonctionnalités principales</h2>
                            <ul>
                                <li><strong>Campagnes SMS personnalisées :</strong> rédigez des messages adaptés à votre audience avec des variables dynamiques.</li>
                                <li><strong>Tableau de bord intuitif :</strong> suivez en temps réel l'état de vos campagnes et votre solde de crédits.</li>
                                <li><strong>Crédits SMS sans expiration :</strong> utilisez-les à votre rythme, ils ne périment jamais.</li>
                                <li><strong>Gestion des organisations :</strong> définissez vos noms d'expéditeurs personnalisés.</li>
                                <li><strong>Segmentation des contacts :</strong> organisez vos contacts en groupes thématiques.</li>
                                <li><strong>Importation Excel :</strong> ajoutez vos contacts en masse via fichier <code>.xlsx</code>.</li>
                                <li><strong>Templates de messages :</strong> sauvegardez vos messages réutilisables.</li>
                                <li><strong>Historique complet :</strong> consultez toutes vos campagnes passées et leurs statuts de livraison.</li>
                                <li><strong>Support client 24h/7j :</strong> assistance par WhatsApp et email.</li>
                            </ul>
                        </div>

                        <!-- Tarification -->
                        <div class="doc-section" id="tarification">
                            <h2><span class="sec-icon"><i class="bi bi-tags"></i></span>Tarification</h2>
                            <p>Un tarif unique et transparent : <strong>0,06 $ par SMS</strong>, sans frais cachés ni abonnement mensuel.</p>
                            <table class="doc-table">
                                <thead>
                                    <tr>
                                        <th>Pack</th>
                                        <th class="text-center">Prix</th>
                                        <th class="text-center">SMS inclus</th>
                                        <th class="text-center">Prix / SMS</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Pack Mini</td>
                                        <td class="text-center">$ 6</td>
                                        <td class="text-center">100 SMS</td>
                                        <td class="text-center">$ 0,06</td>
                                    </tr>
                                    <tr class="featured">
                                        <td>Pack Midi ⭐ Le plus populaire</td>
                                        <td class="text-center">$ 30</td>
                                        <td class="text-center">500 SMS</td>
                                        <td class="text-center">$ 0,06</td>
                                    </tr>
                                    <tr>
                                        <td>Pack Maxi</td>
                                        <td class="text-center">$ 150</td>
                                        <td class="text-center">2 500 SMS</td>
                                        <td class="text-center">$ 0,06</td>
                                    </tr>
                                    <tr>
                                        <td>Pack Personnalisé</td>
                                        <td class="text-center">Variable</td>
                                        <td class="text-center">Sur mesure</td>
                                        <td class="text-center">
                                            <a class="btn btn-sm btn-outline-primary" href="{{ path('app_commande') }}">Configurer</a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="callout callout-info">
                                <i class="bi bi-infinity"></i>
                                <div>Les crédits achetés sont <strong>valables à vie</strong>. Vous ne perdez jamais vos SMS non utilisés.</div>
                            </div>
                        </div>

                        <!-- Inscription & Connexion -->
                        <div class="doc-section" id="authentification">
