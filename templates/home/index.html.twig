{% extends 'base.html.twig' %}

{% block title %}Tableau de bord — MSG-PRO{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/dashboard.css') }}">
{% endblock %}

{% block body %}
<div class="container-fluid py-3">

    <!-- Stat cards -->
    <div class="row g-3 mb-4">
        <div class="col-lg-3 col-sm-6">
            <div class="stat-card stat-blue">
                <i class="fas fa-sms stat-icon"></i>
                <div class="stat-value">
                    {{ app.user.totalSMS is not null ? app.user.totalSMS : 0 }}
                </div>
                <div class="stat-label">SMS disponibles</div>
                <a href="{{ path('app_commande') }}" class="stat-link">Recharger <i class="fas fa-arrow-right"></i></a>
                {% if is_granted('ROLE_ADMIN') %}
                    <div class="balance-hint">Solde opérateur : {{ myBalance }}</div>
                {% endif %}
            </div>
        </div>
        <div class="col-lg-3 col-sm-6">
            <div class="stat-card stat-teal">
                <i class="fas fa-check-circle stat-icon"></i>
                <div class="stat-value">
                    {{ app.user.usedSMS is not null ? app.user.usedSMS : 0 }}
                </div>
                <div class="stat-label">SMS envoyés</div>
                <a href="{{ path('app_historique_index') }}" class="stat-link">Voir l'historique <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
        <div class="col-lg-3 col-sm-6">
            <div class="stat-card stat-amber">
                <i class="fas fa-address-book stat-icon"></i>
                <div class="stat-value">{{ contacts }}</div>
                <div class="stat-label">Contacts</div>
                <a href="{{ path('app_contact_index') }}" class="stat-link">Gérer les contacts <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
        <div class="col-lg-3 col-sm-6">
            <div class="stat-card stat-violet">
                <i class="fas fa-layer-group stat-icon"></i>
                <div class="stat-value">{{ groupes }}</div>
                <div class="stat-label">Groupes de contacts</div>
                <a href="{{ path('app_groupe_index') }}" class="stat-link">Gérer les groupes <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </div>

    <div class="row g-3">

        <!-- Accès rapides + Envoi rapide -->
        <div class="col-lg-8">

            <!-- Accès rapides -->
            <div class="card mb-3">
                <div class="card-header bg-gradient-dark">
                    <h5>Accès rapides</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-4">
                            <a href="{{ path('app_envoi_sms') }}" class="shortcut-card">
                                <div class="sc-icon"><i class="fas fa-paper-plane"></i></div>
                                <span>Envoyer SMS</span>
                            </a>
                        </div>
                        <div class="col-4">
                            <a href="{{ path('app_contact_index') }}" class="shortcut-card">
                                <div class="sc-icon"><i class="fas fa-address-book"></i></div>
                                <span>Contacts</span>
                            </a>
                        </div>
                        <div class="col-4">
                            <a href="{{ path('app_commande') }}" class="shortcut-card">
                                <div class="sc-icon"><i class="fas fa-plus-circle"></i></div>
                                <span>Acheter des SMS</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Derniers envois -->
            <div class="card">
                <div class="card-header bg-gradient-dark">
                    <h5>5 derniers envois</h5>
                </div>
                <div class="card-body p-0">
                    {% if historiques is empty %}
                        <div class="text-center py-5 text-muted">
                            <i class="fas fa-inbox fa-2x mb-2 d-block icon-inbox-empty"></i>
                            <span class="text-sm">Aucun envoi pour l'instant</span>
                        </div>
                    {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Expéditeur</th>
                                    <th>Numéro</th>
                                    <th>Message</th>
                                    <th>Statut</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for h in historiques %}
                                <tr>
                                    <td class="td-date">{{ h.date | format_datetime('short', 'short') }}</td>
                                    <td class="td-sender">{{ h.sender }}</td>
                                    <td>{{ h.numero | replace({'%2b': '+'}) }}</td>
                                    <td class="td-message">
                                        {{ h.message | replace({'+': ' '}) | slice(0, 50) }}{% if h.message | length > 50 %}…{% endif %}
                                    </td>
                                    <td>
                                        {% if h.reponse == '0' or h.reponse == 0 %}
                                            <span class="status-badge status-ok"><i class="fas fa-check me-1"></i> Envoyé</span>
                                        {% elseif h.reponse == '-1' or h.reponse == -1 %}
                                            <span class="status-badge status-fail"><i class="fas fa-times me-1"></i> Échec</span>
                                        {% else %}
                                            <span class="status-badge status-other">{{ h.reponse }}</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% endif %}
                </div>
                {% if historiques is not empty %}
                <div class="card-footer card-footer-right">
                    <a href="{{ path('app_historique_index') }}">
                        Voir tout l'historique <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
                {% endif %}
            </div>

        </div>

        <!-- Envoi rapide -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header bg-gradient-dark">
                    <h5>Envoi SMS rapide</h5>
                </div>
                <div class="card-body quick-send-form">
                    <form id="form-rapide" action="{{ path('EnvoiRapideSMS') }}">
                        <label>Expéditeur</label>
                        <select class="form-control" name="expediteur" id="expediteur">
                            <option value="-1">Choisir un expéditeur</option>
                            {% for organisation in organisations %}
                                <option value="{{ organisation.id }}">
                                    {{ organisation.designation }}
                                    {% if organisation.isApproved %} ✓{% else %} (en attente){% endif %}
                                </option>
                            {% endfor %}
                        </select>

                        <label>Numéro de téléphone</label>
                        <input type="number" name="numero" class="form-control" placeholder="ex : 0851234567">

                        <label>Message</label>
                        <textarea name="message" class="form-control" rows="4" placeholder="Rédigez votre message..."></textarea>

                        <span id="error-msg" class="text-danger d-block mb-2"></span>

                        <button id="btn-envoyer" type="submit" class="btn btn-primary w-100 btn-send-quick">
                            <i class="fas fa-paper-plane mr-2"></i> Envoyer
                        </button>
                    </form>
                </div>
            </div>
        </div>

    </div>
</div>

<script src="{{ asset('plugins/jquery/jquery.js') }}"></script>
<script>
$('#btn-envoyer').on('click', function(e) {
    let qty = parseInt($('#qty-sms').text()) || 0;
    if (qty <= 0) {
        $('#error-msg').text('Solde insuffisant. Veuillez recharger votre compte.');
        e.preventDefault();
    } else {
        $('#error-msg').text('');
    }
});
</script>
{% endblock %}
