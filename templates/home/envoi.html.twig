{% extends 'base.html.twig' %}

{% block title %}Envoyer SMS — MSG-PRO{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/envoi.css') }}">
<link rel="stylesheet" href="{{ asset('plugins/select2/css/select2.min.css') }}">
<link rel="stylesheet" href="{{ asset('plugins/select2-bootstrap4-theme/select2-bootstrap4.min.css') }}">
{% endblock %}

{% block body %}
    <div class="container-fluid py-3">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <!-- Avertissement expéditeur -->
                <div class="callout-warning-box">
                    <i class="fas fa-exclamation-triangle"></i>
                    <div>
                        Si votre organisation n'est pas encore approuvée par les opérateurs réseau, <strong>insoft</strong> sera utilisé comme expéditeur par défaut.
                        <a href="{{ path('app_commande') }}" class="link-warning">Demander l'approbation →</a>
                    </div>
                </div>

                <div class="card envoi-form">
                    <div class="card-header bg-gradient-dark">
                        <h5>Nouvelle campagne SMS</h5>
                    </div>
                    <div class="card-body card-body-padded">

                        <!-- Expéditeur & groupe -->
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label>Expéditeur (Organisation)</label>
                                <select name="organisation" id="organisation" class="form-control">
                                    <option value="-1">Choisir une organisation</option>
                                    {% for organisation in organisations %}
                                        <option value="{{ organisation.id }}">
                                            {{ organisation.designation }}
                                            {% if organisation.isApproved %} ✓ Approuvée{% else %} — En attente{% endif %}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label>Groupe de contacts</label>
                                <select name="listes" id="listes" class="form-control">
                                    <option value="-1">Choisir un groupe</option>
                                    {% for groupe in groupes %}
                                        <option value="{{ groupe.id }}">{{ groupe.designation }} ({{ groupe.totalContact }} contacts)</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>

                        <hr class="hr-light">

                        <!-- Template -->
                        <div class="mb-3">
                            <label>Modèle de message <span class="label-optional">(optionnel)</span></label>
                            <select name="template" id="template" class="form-control">
                                <option value="-1">Choisir un modèle existant</option>
                                {% for template in templates %}
                                    <option value="{{ template.texte }}">{{ template.titre }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <!-- Message -->
                        <div class="mb-3">
                            <div class="message-header">
                                <label class="mb-0">Message</label>
                                <button id="save-model" type="button" class="btn btn-sm btn-info d-none btn-save-model"
                                        data-toggle="modal" data-target="#modal-default">
                                    <i class="fas fa-save me-1"></i> Sauvegarder comme modèle
                                </button>
                            </div>

                            <div class="variables-row">
                                <span class="variables-label">Insérer :</span>
                                <button class="btn-variable btn-include">[Nom]</button>
                                <button class="btn-variable btn-include">[Postnom]</button>
                                <button class="btn-variable btn-include">[Fonction]</button>
                                <button class="btn-variable btn-include">[Adresse]</button>
                            </div>

                            <textarea name="message" maxlength="159" id="message" rows="5" class="form-control"
                                      placeholder="Rédigez votre message SMS ici..."></textarea>

                            <div class="char-counter">
                                <span><span id="longueur">0</span> / 160 caractères</span>
                                <div class="bar"><div class="bar-fill" id="bar-fill" style="width:0%"></div></div>
                                <span id="erreur-longueur" class="text-danger d-none error-inline">
                                    <i class="fas fa-info-circle me-1"></i> Longueur variable avec les balises
                                </span>
                            </div>
                        </div>

                        <button type="button" id="btn-envoyer-sms" class="btn btn-primary w-100 btn-send-campaign">
                            <i class="fas fa-paper-plane me-2"></i> Envoyer la campagne
                        </button>

                        <!-- Feedback envoi -->
                        <div id="feedback-success" class="feedback-box feedback-success d-none mt-3">
                            <i class="fas fa-check-circle"></i>
                            <div>
                                <strong id="feedback-count"></strong>
                                <div style="font-size:0.85rem;margin-top:2px;">
                                    <a href="{{ path('app_historique_index') }}" class="feedback-link">Voir l'historique →</a>
                                </div>
                            </div>
                        </div>
                        <div id="feedback-error" class="feedback-box feedback-error d-none mt-3">
                            <i class="fas fa-exclamation-circle"></i>
                            <span id="feedback-error-msg"></span>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>


    <div class="modal fade" id="modal-default">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title">Entrez le titre du Modele de SMS</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <input type="text" class="form-control" id="titre">
                </div>
                <div class="modal-footer justify-content-between">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
                    <button id="enregistrer-model" type="button"  data-dismiss="modal" class="btn btn-primary">Enregistrer</button>
                </div>
            </div>
            <!-- /.modal-content -->
        </div>
        <!-- /.modal-dialog -->
    </div>
    <!-- /.modal -->

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset("plugins/select2/js/select2.min.js") }}"></script>
    <script>
        $(document).ready(function(){

            $('#organisation').select2({ theme: 'bootstrap4', placeholder: 'Choisir une organisation', allowClear: true, width: '100%' });
            $('#listes').select2({ theme: 'bootstrap4', placeholder: 'Choisir un groupe', allowClear: true, width: '100%' });
            $('#template').select2({ theme: 'bootstrap4', placeholder: 'Choisir un modèle existant', allowClear: true, width: '100%' });

            // Focus automatique sur le champ de recherche à l'ouverture
            $(document).on('select2:open', function() {
                document.querySelector('.select2-container--open .select2-search__field').focus();
            });

            $('.btn-include').click(function() {
                var texteAInserer = $(this).text();
                var element = $('#message'); // Remplacez par l'id de votre champ de texte
                var valeurActuelle = element.val();
                var positionCurseur = element[0].selectionStart;

                element.val(valeurActuelle.substring(0, positionCurseur) + texteAInserer + valeurActuelle.substring(positionCurseur) + ' ');
                element.focus()
                $("#texte-longueur")
                    //.text('Impossible de mesurer la longueur des valeurs des variables.')
                    .addClass('d-none')
                $("#erreur-longueur").removeClass('d-none')
            });

            /////
            $('#template').on("change", function(e){
                //alert("bien")
                if($(this).val() == -1){
                    $("#message").val("")
                }else{
                    $("#message").val($(this).val())
                    $("#longueur").text($("#message").val().length)
                }
            })

            $("#message").on("keyup", function(e){
                //console.log($(this).val().length)
                $("#longueur").text($(this).val().length)
                let longueur = $(this).val().length
                let message = $("#message").val()
                //check if the length of text to hide or display the button
                if(longueur === 0){
                    $("#save-model").addClass("d-none")
                }else{
                    $(this).removeClass('border border-danger')
                    $("#save-model").removeClass("d-none")
                    //let nbresms = (longueur / 160) + 1
                    //$("#nombre-sms").text(parseInt(nbresms))
                    //console.log('nbresms', parseInt(nbresms))
                    if(message.indexOf('[Nom]') !== -1 || message.indexOf('[Postnom]') !== -1 || message.indexOf('[Adresse]') !== -1){
                        $("#erreur-longueur").removeClass('d-none')

                    } else {
                        $("#erreur-longueur").addClass('d-none')
                        $("#message").removeClass('d-none')
                    }
                }

            })

            //to save a message model
            $("#save-model").on('click', function(e){
                console.log($('#message').val())
            })

            //confirm saving of the template
            $("#enregistrer-model").click(function(e){
                //console.log($('#message').val(), $('#titre').val())
                $.ajax({
                    url: 'JsonSaveTemplate?titre=' +
                        encodeURIComponent($('#titre').val()) + '&texte=' + encodeURIComponent($('#message').val()),
                    method: 'GET',
                    data: {},
                    success: function (data) {
                        //console.log(data, 'done')
                        //$('#modal-default').toggle()
                    },
                    error: function () {
                        $("#erreur-longueur").text("Impossible d'enregistrer le modèle. Réessayez.").removeClass("d-none");
                    }
                    //let qty = $(this).parent("td").siblings("td").children("input[x-model='item.quantity']")
                })
            })

            $("#btn-envoyer-sms").on("click", function(e){
                let message = $("#message").val()
                let listID = $("#listes").val()
                let sender = $("#organisation").val()

                $("#feedback-success, #feedback-error").addClass('d-none')
                $("#organisation, #message, #listes").removeClass('border border-danger')

                if(sender < 0){
                    $("#organisation").addClass('border border-danger'); return;
                }
                if(listID < 0){
                    $("#listes").addClass('border border-danger'); return;
                }
                if(message.length <= 0){
                    $("#message").addClass('border border-danger'); return;
                }

                let $btn = $(this)
                $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i> Envoi en cours…')

                $.ajax({
                    url: 'JsonEnvoyerSMS?sender='+encodeURIComponent(sender)+'&message='+encodeURIComponent(message)+'&groupeID='+encodeURIComponent(listID)+'&expID='+encodeURIComponent(sender),
                    method: 'GET',
                    success: function(data) {
                        $btn.prop('disabled', false).html('<i class="fas fa-paper-plane me-2"></i> Envoyer la campagne')
                        if(typeof data === 'string' && data.includes('%2b')) {
                            // success: backend returned phone numbers string
                            let count = (data.match(/%2b/g) || []).length
                            $("#feedback-count").text(count + ' SMS envoyé' + (count > 1 ? 's' : '') + ' avec succès !')
                            $("#feedback-success").removeClass('d-none')
                            $("#message").val('')
                            $("#longueur").text('0')
                        } else {
                            // backend returned an error message string
                            $("#feedback-error-msg").text(data)
                            $("#feedback-error").removeClass('d-none')
                        }
                    },
                    error: function() {
                        $btn.prop('disabled', false).html('<i class="fas fa-paper-plane me-2"></i> Envoyer la campagne')
                        $("#feedback-error-msg").text("Échec de l'envoi. Vérifiez votre connexion et réessayez.")
                        $("#feedback-error").removeClass('d-none')
                    }
                })
            })
        })
    </script>
{% endblock %}
