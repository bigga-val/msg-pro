{% extends 'base_landing.html.twig' %}

{% block title %}MSG-PRO : Envoi de SMS en Masse en RDC — Vodacom, Airtel, Orange, Africell{% endblock %}
{% block meta_description %}MSG-PRO est la plateforme SMS #1 en République Démocratique du Congo. Envoyez des SMS en masse sur tous les réseaux (Vodacom, Airtel, Orange, Africell) à seulement 0,06 $/SMS. Pack à partir de 6 $. Inscription gratuite, 5 SMS offerts.{% endblock %}
{% block og_title %}MSG-PRO : Envoi de SMS en Masse en RDC — 0,06 $/SMS{% endblock %}
{% block og_description %}La plateforme SMS professionnelle pour entreprises et particuliers en RDC. Tous réseaux couverts, crédits sans expiration, support 24/7. Pack dès 6 $.{% endblock %}
{% block canonical %}https://msg-pro.com/{% endblock %}

{% block stylesheets %}
<style>
/* ========== PALETTE BLEUE PRO ========== */
:root {
    --accent-color: #2563eb;
    --nav-hover-color: #2563eb;
    --nav-dropdown-hover-color: #2563eb;
}
.header {
    --background-color: #1a2e5a;
}
.dark-background {
    --background-color: #1a2e5a;
}

/* ========== HERO ========== */
.hero {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
}
.hero img {
    object-fit: cover;
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
    filter: brightness(0.45);
}
.hero .container {
    position: relative;
    z-index: 2;
    padding-top: 160px;
    padding-bottom: 100px;
}
.hero h1 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 800;
    line-height: 1.2;
    color: #fff;
    margin-bottom: 1rem;
}
.hero .hero-tagline {
    font-size: 1.15rem;
    color: rgba(255,255,255,0.82);
    margin-bottom: 2rem;
    max-width: 520px;
}
.hero .hero-btns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
}
.hero .btn-get-started {
    background: var(--accent-color);
    color: #fff;
    padding: 14px 36px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.5px;
    transition: 0.3s;
    display: inline-block;
}
.hero .btn-get-started:hover {
    background: #1d4ed8;
    color: #fff;
}
.hero .btn-outline-hero {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255,255,255,0.7);
    padding: 12px 34px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 1rem;
    transition: 0.3s;
    display: inline-block;
}
.hero .btn-outline-hero:hover {
    background: rgba(255,255,255,0.15);
    border-color: #fff;
    color: #fff;
}

/* Stats bar inside hero */
.hero-stats {
    position: relative;
    z-index: 2;
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(10px);
    border-top: 1px solid rgba(255,255,255,0.15);
    padding: 24px 0;
    margin-top: auto;
}
.hero-stats .stat-item {
    text-align: center;
    color: #fff;
    padding: 0 20px;
}
.hero-stats .stat-number {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--accent-color);
    line-height: 1;
    font-family: var(--heading-font);
}
.hero-stats .stat-label {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.75);
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
}
.hero-stats .stat-divider {
    width: 1px;
    background: rgba(255,255,255,0.2);
    align-self: stretch;
}

/* ========== ABOUT ========== */
.about .content ul li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 14px;
    font-size: 0.97rem;
}
.about .content ul li i {
    color: var(--accent-color);
    font-size: 1.1rem;
    margin-top: 2px;
    flex-shrink: 0;
}
.about .content img {
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.12);
}
.about .content .about-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #eff6ff;
    color: var(--accent-color);
    border: 1px solid #bfdbfe;
    border-radius: 20px;
    padding: 5px 14px;
    font-size: 0.82rem;
    font-weight: 600;
    margin-bottom: 14px;
}

/* ========== SERVICES ========== */
.services .service-item {
    background: #fff;
    border: 1px solid #f0f0f0;
    border-radius: 12px;
    padding: 36px 28px 28px;
    transition: all 0.35s ease;
    height: 100%;
    box-shadow: 0 2px 16px rgba(0,0,0,0.04);
}
.services .service-item:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(37,99,235,0.12);
    border-color: rgba(37,99,235,0.15);
}
.services .service-item .icon {
    width: 64px;
    height: 64px;
    border-radius: 12px;
    background: #eff6ff;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    transition: 0.3s;
}
.services .service-item:hover .icon {
    background: var(--accent-color);
}
.services .service-item .icon i {
    font-size: 1.7rem;
    color: var(--accent-color);
    transition: 0.3s;
}
.services .service-item:hover .icon i {
    color: #fff;
}
.services .service-item h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: #191919;
}
.services .service-item p {
    color: #666;
    font-size: 0.93rem;
    line-height: 1.65;
    margin-bottom: 0;
}

/* ========== PRICING ========== */
.pricing .pricing-item {
    border-radius: 16px;
    border: 2px solid #e2e8f0;
    padding: 36px 30px;
    background: #f8fafc;
    transition: 0.3s;
    position: relative;
    height: 100%;
}
.pricing .pricing-item:hover {
    border-color: var(--accent-color);
    box-shadow: 0 12px 40px rgba(37,99,235,0.12);
    transform: translateY(-3px);
}

/* Pack Mini — teinte bleue très légère */
.pricing .col-lg-4:first-child .pricing-item {
    background: #eff6ff;
    border-color: #bfdbfe;
}

/* Pack Midi (featured) — fond bleu foncé, texte blanc */
.pricing .featured .pricing-item {
    background: linear-gradient(145deg, #1e3a8a 0%, #2563eb 100%);
    border-color: #2563eb;
    box-shadow: 0 12px 48px rgba(37,99,235,0.35);
    transform: scale(1.03);
    color: #fff;
}
.pricing .featured .pricing-item:hover {
    transform: scale(1.03) translateY(-3px);
    box-shadow: 0 20px 56px rgba(37,99,235,0.45);
}

/* Pack Maxi — teinte ambre/dorée */
.pricing .col-lg-4:last-child .pricing-item {
    background: #fffbeb;
    border-color: #fcd34d;
}

.pricing .badge-popular {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: #f59e0b;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 18px;
    border-radius: 20px;
    letter-spacing: 0.8px;
    white-space: nowrap;
}
.pricing .badge-saving {
    display: inline-block;
    background: rgba(255,255,255,0.2);
    color: #1d4ed8;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    margin-bottom: 10px;
}
.pricing .featured .badge-saving {
    background: rgba(255,255,255,0.2);
    color: #fff;
}
.pricing .pricing-item h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1e3a8a;
    margin-bottom: 6px;
}
.pricing .featured .pricing-item h3 {
    color: rgba(255,255,255,0.85);
}
.pricing .pricing-item h4 {
    font-size: 2.6rem;
    font-weight: 800;
    color: #191919;
    margin-bottom: 2px;
}
.pricing .featured .pricing-item h4 {
    color: #fff;
}
.pricing .pricing-item h4 sup {
    font-size: 1.2rem;
    top: -10px;
    color: var(--accent-color);
}
.pricing .featured .pricing-item h4 sup {
    color: #93c5fd;
}
.pricing .pricing-item h4 span {
    font-size: 0.9rem;
    font-weight: 400;
    color: #888;
}
.pricing .featured .pricing-item h4 span {
    color: rgba(255,255,255,0.65);
}
.pricing .pricing-item .old-price {
    font-size: 0.85rem;
    color: #aaa;
    text-decoration: line-through;
    margin-bottom: 16px;
}
.pricing .featured .pricing-item .old-price {
    color: rgba(255,255,255,0.5);
}
.pricing .pricing-item .features-list {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    border-top: 1px solid rgba(0,0,0,0.07);
    padding-top: 20px;
}
.pricing .featured .pricing-item .features-list {
    border-top-color: rgba(255,255,255,0.2);
}
.pricing .pricing-item .features-list li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    color: #555;
    padding: 5px 0;
}
.pricing .featured .pricing-item .features-list li {
    color: rgba(255,255,255,0.88);
}
.pricing .pricing-item .features-list li i {
    color: #2563eb;
    font-size: 0.95rem;
    flex-shrink: 0;
}
.pricing .featured .pricing-item .features-list li i {
    color: #93c5fd;
}
.pricing .buy-btn {
    display: block;
    width: 100%;
    text-align: center;
    background: var(--accent-color);
    color: #fff;
    padding: 12px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: 0.3s;
    letter-spacing: 0.3px;
}
.pricing .buy-btn:hover {
    background: #1d4ed8;
    color: #fff;
}
.pricing .featured .buy-btn {
    background: #fff;
    color: #1e3a8a;
    font-weight: 700;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
}
.pricing .featured .buy-btn:hover {
    background: #f0f9ff;
    color: #1e3a8a;
}

/* Pack personnalisé */
.custom-pack-section {
    background: linear-gradient(135deg, #eff6ff 0%, #fff 100%);
    border: 2px dashed rgba(37,99,235,0.3);
    border-radius: 16px;
    padding: 36px;
    text-align: center;
    margin-top: 32px;
}
.custom-pack-section h3 {
    font-size: 1.4rem;
    font-weight: 700;
    color: #191919;
    margin-bottom: 10px;
}
.custom-pack-section p {
    color: #666;
    margin-bottom: 20px;
}
.custom-pack-section .btn-custom {
    background: var(--accent-color);
    color: #fff;
    padding: 12px 32px;
    border-radius: 8px;
    font-weight: 600;
    transition: 0.3s;
    display: inline-block;
}
.custom-pack-section .btn-custom:hover {
    background: #1d4ed8;
    color: #fff;
}

/* ========== CTA ========== */
.call-to-action {
    background: linear-gradient(135deg, #0f1f3d 0%, #1a2e5a 50%, #2563eb 100%);
    position: relative;
    overflow: hidden;
}
.call-to-action::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("{{ asset('landing/assets/img/cta-bg.jpg') }}") center/cover no-repeat;
    opacity: 0.08;
}
.call-to-action .container {
    position: relative;
    z-index: 2;
}
.call-to-action h3 {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 800;
    color: #fff;
    margin-bottom: 16px;
}
.call-to-action p {
    color: rgba(255,255,255,0.82);
    max-width: 600px;
    margin: 0 auto 28px;
    font-size: 1rem;
    line-height: 1.7;
}
.call-to-action .cta-btn {
    background: #fff;
    color: var(--accent-color);
    padding: 14px 40px;
    border-radius: 4px;
    font-weight: 700;
    font-size: 1rem;
    transition: 0.3s;
    display: inline-block;
    letter-spacing: 0.5px;
}
.call-to-action .cta-btn:hover {
    background: var(--accent-color);
    color: #fff;
}

/* ========== CONTACT ========== */
.contact .info-item {
    background: #fff;
    border: 1px solid #f0f0f0;
    border-radius: 12px;
    padding: 28px 20px;
    text-align: center;
    box-shadow: 0 2px 16px rgba(0,0,0,0.05);
    transition: 0.3s;
    height: 100%;
}
.contact .info-item:hover {
    border-color: rgba(37,99,235,0.2);
    box-shadow: 0 8px 30px rgba(37,99,235,0.08);
    transform: translateY(-3px);
}
.contact .info-item i {
    font-size: 2rem;
    color: var(--accent-color);
    margin-bottom: 14px;
    display: block;
}
.contact .info-item h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: #191919;
}
.contact .info-item p, .contact .info-item a {
    color: #666;
    font-size: 0.93rem;
    margin: 0;
}
.contact iframe {
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
}
.contact .form-control {
    border-radius: 8px;
    border: 1.5px solid #e8e8e8;
    padding: 12px 16px;
    font-size: 0.93rem;
    transition: 0.3s;
}
.contact .form-control:focus {
    border-color: var(--accent-color);
    box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
}
.contact form button[type="submit"] {
    background: var(--accent-color);
    color: #fff;
    border: none;
    padding: 13px 40px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: 0.3s;
    width: 100%;
}
.contact form button[type="submit"]:hover {
    background: #1d4ed8;
}
</style>

