{% extends 'base_landing.html.twig' %}

{% block title %}MSG-PRO : Envoi de SMS en Masse en RDC — Vodacom, Airtel, Orange, Africell{% endblock %}
{% block meta_description %}MSG-PRO est la plateforme SMS #1 en République Démocratique du Congo. Envoyez des SMS en masse sur tous les réseaux (Vodacom, Airtel, Orange, Africell) à seulement 0,06 $/SMS. Pack à partir de 6 $. Inscription gratuite, 5 SMS offerts.{% endblock %}
{% block og_title %}MSG-PRO : Envoi de SMS en Masse en RDC — 0,06 $/SMS{% endblock %}
{% block og_description %}La plateforme SMS professionnelle pour entreprises et particuliers en RDC. Tous réseaux couverts, crédits sans expiration, support 24/7. Pack dès 6 $.{% endblock %}
{% block canonical %}https://msg-pro.com/{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('styles/landing.css') }}">

<!-- JSON-LD Structured Data -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://msg-pro.com/#organization",
      "name": "MSG-PRO",
      "url": "https://msg-pro.com/",
      "logo": "{{ absolute_url(asset('msg-logo.PNG')) }}",
      "description": "Plateforme d'envoi de SMS en masse en République Démocratique du Congo. Tous réseaux : Vodacom, Airtel, Orange, Africell.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "1434 RN39",
        "addressLocality": "Kolwezi",
        "addressRegion": "Lualaba",
        "addressCountry": "CD"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+243851331051",
        "contactType": "customer support",
        "availableLanguage": ["French"]
      },
      "sameAs": [
        "https://www.facebook.com/profile.php?id=61575012670787",
        "https://www.linkedin.com/company/106139815/"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://msg-pro.com/#website",
      "url": "https://msg-pro.com/",
      "name": "MSG-PRO",
      "publisher": { "@id": "https://msg-pro.com/#organization" },
      "inLanguage": "fr"
    },
    {
      "@type": "ItemList",
      "name": "Tarifs SMS MSG-PRO",
      "description": "Packs SMS professionnels pour entreprises et particuliers en RDC à 0,06 $/SMS",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": {
            "@type": "Offer",
            "name": "Pack Mini — 100 SMS",
            "description": "100 SMS valables à vie, tous réseaux (Vodacom, Airtel, Orange, Africell), tableau de bord inclus, support WhatsApp.",
            "price": "6",
            "priceCurrency": "USD",
            "url": "https://msg-pro.com/"
          }
        },
        {
          "@type": "ListItem",
          "position": 2,
          "item": {
            "@type": "Offer",
            "name": "Pack Midi — 500 SMS",
            "description": "500 SMS valables à vie, tous réseaux, tableau de bord, envoi de groupe, support prioritaire.",
            "price": "30",
            "priceCurrency": "USD",
            "url": "https://msg-pro.com/"
          }
        },
        {
          "@type": "ListItem",
          "position": 3,
          "item": {
            "@type": "Offer",
            "name": "Pack Maxi — 2500 SMS",
            "description": "2 500 SMS valables à vie, tous réseaux, importation de contacts Excel, support prioritaire 24/7.",
            "price": "150",
            "priceCurrency": "USD",
            "url": "https://msg-pro.com/"
          }
        }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Les crédits SMS expirent-ils ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Non, vos crédits SMS MSG-PRO sont valables à vie. Utilisez-les à votre rythme, sans date d'expiration."
          }
        },
        {
          "@type": "Question",
          "name": "Quels réseaux sont couverts en RDC ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "MSG-PRO couvre tous les grands réseaux en République Démocratique du Congo : Vodacom, Airtel, Orange et Africell."
          }
        },
        {
          "@type": "Question",
          "name": "Quel est le prix d'un SMS avec MSG-PRO ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Le prix est de 0,06 $ par SMS, soit 6 $ pour 100 SMS. C'est l'un des tarifs les plus compétitifs du marché en RDC."
          }
        },
        {
          "@type": "Question",
          "name": "Comment créer un compte MSG-PRO ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "L'inscription est gratuite sur msg-pro.com. Vous recevez 5 SMS offerts immédiatement à la création de votre compte."
          }
        }
      ]
    }
  ]
}
</script>
{% endblock %}

{% block body %}

    <header id="header" class="header fixed-top">

        <div class="topbar d-flex align-items-center">
            <div class="container d-flex justify-content-center justify-content-md-between">
                <div class="contact-info d-flex align-items-center">
                    <i class="bi bi-envelope d-flex align-items-center"><a href="mailto:info@msg-pro.com">info@msg-pro.com</a></i>
                    <i class="bi bi-phone d-flex align-items-center ms-4"><span>+243 851 331 051</span></i>
                </div>
                <div class="social-links d-none d-md-flex align-items-center">
                    <a href="#" class="twitter"><i class="bi bi-twitter-x"></i></a>
                    <a href="https://www.facebook.com/profile.php?id=61575012670787" class="facebook"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="instagram"><i class="bi bi-instagram"></i></a>
                    <a href="https://www.linkedin.com/company/106139815/" class="linkedin"><i class="bi bi-linkedin"></i></a>
                </div>
            </div>
        </div><!-- End Top Bar -->

        <div class="branding d-flex align-items-center">
            <div class="container position-relative d-flex align-items-center justify-content-between">
                <a href="" class="logo d-flex align-items-center">
                    <img src="{{ asset('msg-logo.PNG') }}" alt="MSG-PRO logo">
                    <h1 class="sitename">MSG-PRO</h1>
                </a>

                <nav id="navmenu" class="navmenu">
                    <ul>
                        <li><a href="#hero" class="active">Home</a></li>
                        <li><a href="#about">A Propos</a></li>
                        <li><a href="#services">Services</a></li>
                        <li><a href="#tarifs">Tarifs</a></li>
                        <li><a href="#contact">Contact</a></li>
                        {% if app.user %}
                            <a href="{{ path("app_home") }}" class="btn btn-outline-danger btn-sm">{{ app.user.username }}</a>
                        {% else %}
                            <li><a href="{{ path("app_login") }}">Connexion</a></li>
                        {% endif %}
                    </ul>
                    <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
                </nav>
            </div>
        </div>

    </header>

    <main class="main">

        <!-- Hero Section -->
        <section id="hero" class="hero section dark-background d-flex flex-column">

            <img src="{{ asset('landing/assets/img/hero-bg.jpg') }}" alt="Envoi SMS professionnel en RDC" data-aos="fade-in">

            <div class="container" data-aos="fade-up" data-aos-delay="100">
                <div class="row justify-content-start">
                    <div class="col-lg-7">
                        <p class="hero-tagline"><i class="bi bi-patch-check-fill me-2 icon-accent"></i>La plateforme SMS #1 en République Démocratique du Congo</p>
                        <h1>Envoyez des SMS en masse, rapidement et à moindre coût</h1>
                        <p class="hero-tagline">Touchez vos clients sur tous les réseaux — Vodacom, Airtel, Orange, Africell — en quelques clics.</p>
                        <div class="hero-btns">
                            <a href="#tarifs" class="btn-get-started">Voir les tarifs</a>
                            <a href="{{ path("app_register") }}" class="btn-get-started">Créer un compte gratuit</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stats bar -->
            <div class="hero-stats mt-auto" data-aos="fade-up" data-aos-delay="300">
                <div class="container">
                    <div class="row justify-content-center text-center gy-3">
                        <div class="col-6 col-md-3">
                            <div class="stat-item">
                                <div class="stat-number">4</div>
                                <div class="stat-label">Réseaux couverts</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="stat-item">
                                <div class="stat-number">0,06$</div>
                                <div class="stat-label">Par SMS</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="stat-item">
                                <div class="stat-number">5 SMS</div>
                                <div class="stat-label">Offerts à l'inscription</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="stat-item">
                                <div class="stat-number">24/7</div>
                                <div class="stat-label">Support disponible</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </section><!-- /Hero Section -->

        <!-- About Section -->
        <section id="about" class="about section">

            <div class="container section-title" data-aos="fade-up">
                <span>A Propos</span>
                <h2>A Propos</h2>
                <p>Vos campagnes SMS, boostées à la vitesse de la lumière</p>
            </div>

            <div class="container">
                <div class="row gy-4 align-items-center">

                    <div class="col-lg-6 order-1 order-lg-2" data-aos="fade-up" data-aos-delay="100">
                        <img src="{{ asset('landing/assets/img/about.jpg') }}" class="img-fluid" alt="Tableau de bord MSG-PRO">
                    </div>

                    <div class="col-lg-6 order-2 order-lg-1 content" data-aos="fade-up" data-aos-delay="200">
                        <span class="about-badge"><i class="bi bi-award-fill"></i> Solution SMS professionnelle</span>
                        <h3>Gagnez du temps, boostez votre communication. Le SMS simplifié pour tous</h3>
                        <p class="fst-italic">
                            Nous sommes spécialisés dans la fourniture de solutions d'envoi de SMS en masse pour les entreprises, associations et particuliers en RDC. Notre plateforme robuste vous permet de créer et d'envoyer des campagnes SMS ciblées, avec un taux de livraison élevé sur tous les réseaux.
                        </p>
                        <ul>
                            <li><i class="bi bi-check-circle-fill"></i> <span>Tableau de bord intuitif pour le suivi en temps réel de vos SMS</span></li>
                            <li><i class="bi bi-check-circle-fill"></i> <span>Vos crédits SMS n'expirent jamais — utilisez-les à votre rythme</span></li>
                            <li><i class="bi bi-check-circle-fill"></i> <span>Gestion automatique de votre stock de SMS</span></li>
                            <li><i class="bi bi-check-circle-fill"></i> <span>5 SMS offerts dès la création de votre compte</span></li>
                        </ul>
                        <a href="{{ path("app_register") }}" class="read-more"><span>Créer mon compte</span><i class="bi bi-arrow-right"></i></a>
                    </div>

                </div>
            </div>

        </section><!-- /About Section -->

        <!-- Services Section -->
        <section id="services" class="services section light-background">

            <div class="container section-title" data-aos="fade-up">
                <span>Services</span>
                <h2>Services</h2>
                <p>Tout ce dont vous avez besoin pour gérer vos campagnes SMS efficacement</p>
            </div>

            <div class="container">
                <div class="row gy-4">

                    <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
                        <div class="service-item position-relative">
                            <div class="icon"><i class="bi bi-phone"></i></div>
                            <h3>Facile à utiliser</h3>
                            <p>Interface intuitive pensée pour tous. Pas besoin d'expertise technique — envoyez votre première campagne en moins de 5 minutes.</p>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
                        <div class="service-item position-relative">
                            <div class="icon"><i class="bi bi-lightning-charge-fill"></i></div>
                            <h3>Envoi Ultra-Rapide</h3>
                            <p>Traitement en temps réel des grands volumes. Des milliers de SMS délivrés en quelques secondes pour des campagnes efficaces.</p>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="300">
                        <div class="service-item position-relative">
                            <div class="icon"><i class="bi bi-headset"></i></div>
                            <h3>Support Dédié</h3>
                            <p>Une équipe disponible 24h/7j pour vous accompagner, répondre à vos questions et résoudre tout problème rapidement.</p>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="400">
                        <div class="service-item position-relative">
                            <div class="icon"><i class="bi bi-people-fill"></i></div>
                            <h3>Ciblage Précis</h3>
                            <p>Segmentez vos contacts par groupe, localisation ou profil pour envoyer le bon message à la bonne personne au bon moment.</p>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="500">
                        <div class="service-item position-relative">
                            <div class="icon"><i class="bi bi-send-fill"></i></div>
                            <h3>Envoi Massif</h3>
                            <p>Envoyez simultanément à des milliers de destinataires sur tous les réseaux — Vodacom, Airtel, Orange et Africell.</p>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="600">
                        <div class="service-item position-relative">
                            <div class="icon"><i class="bi bi-shield-check"></i></div>
                            <h3>Fiable & Sécurisé</h3>
                            <p>Haute disponibilité garantie avec un taux de livraison optimal, même en cas de pic de trafic ou de volumes importants.</p>
                        </div>
                    </div>

                </div>
            </div>

        </section><!-- /Services Section -->

        <!-- Call To Action Section -->
        <section id="call-to-action" class="call-to-action section dark-background">

            <div class="container">
                <div class="row justify-content-center" data-aos="zoom-in" data-aos-delay="100">
                    <div class="col-xl-8 text-center">
                        <h3>Prêt à booster votre communication ?</h3>
                        <p>Rejoignez les entreprises, associations et particuliers qui font confiance à MSG-PRO pour leurs campagnes SMS en RDC. Inscription gratuite, 5 SMS offerts immédiatement.</p>
                        <a class="cta-btn" href="{{ path("app_register") }}">Commencer gratuitement <i class="bi bi-arrow-right ms-2"></i></a>
                    </div>
                </div>
            </div>

        </section><!-- /Call To Action Section -->

        <!-- Pricing Section -->
        <section id="tarifs" class="pricing section">

            <div class="container section-title" data-aos="fade-up">
                <span>Tarifs</span>
                <h2>Tarifs</h2>
                <p>Des forfaits simples et transparents. <strong>0,06 $ / SMS</strong> — sans frais cachés.</p>
            </div>

            <div class="container">
                <div class="row g-4 align-items-stretch">

                    <div class="col-lg-4" data-aos="zoom-in" data-aos-delay="100">
                        <div class="pricing-item">
                            <h3>Pack Mini</h3>
                            <div class="badge-saving">Économisez 29 %</div>
                            <h4><sup>$</sup>6<span> / 100 SMS</span></h4>
                            <p class="old-price">Prix habituel : $ 8.5</p>
                            <ul class="features-list">
                                <li><i class="bi bi-check-circle-fill"></i> 100 SMS valables à vie</li>
                                <li><i class="bi bi-check-circle-fill"></i> Tous réseaux (Vodacom, Airtel, Orange, Africell)</li>
                                <li><i class="bi bi-check-circle-fill"></i> Tableau de bord inclus</li>
                                <li><i class="bi bi-check-circle-fill"></i> Support par WhatsApp</li>
                            </ul>
                            <a href="{{ path("app_confirmer_commande", {prix:0.06, montant:6}) }}" class="buy-btn">Commander</a>
                        </div>
                    </div>

                    <div class="col-lg-4 featured" data-aos="zoom-in" data-aos-delay="200">
                        <div class="pricing-item">
                            <span class="badge-popular">⭐ Le plus populaire</span>
                            <h3>Pack Midi</h3>
                            <div class="badge-saving">Économisez 29 %</div>
                            <h4><sup>$</sup>30<span> / 500 SMS</span></h4>
                            <p class="old-price">Prix habituel : $ 42.5</p>
                            <ul class="features-list">
                                <li><i class="bi bi-check-circle-fill"></i> 500 SMS valables à vie</li>
                                <li><i class="bi bi-check-circle-fill"></i> Tous réseaux (Vodacom, Airtel, Orange, Africell)</li>
                                <li><i class="bi bi-check-circle-fill"></i> Tableau de bord inclus</li>
                                <li><i class="bi bi-check-circle-fill"></i> Envoi de groupe & personnalisation</li>
                                <li><i class="bi bi-check-circle-fill"></i> Support prioritaire</li>
                            </ul>
                            <a href="{{ path("app_confirmer_commande", {prix:0.06, montant:30}) }}" class="buy-btn">Commander</a>
                        </div>
                    </div>

                    <div class="col-lg-4" data-aos="zoom-in" data-aos-delay="300">
                        <div class="pricing-item">
                            <h3>Pack Maxi</h3>
                            <div class="badge-saving">Économisez 29 %</div>
                            <h4><sup>$</sup>150<span> / 2500 SMS</span></h4>
                            <p class="old-price">Prix habituel : $ 212.5</p>
                            <ul class="features-list">
                                <li><i class="bi bi-check-circle-fill"></i> 2 500 SMS valables à vie</li>
                                <li><i class="bi bi-check-circle-fill"></i> Tous réseaux (Vodacom, Airtel, Orange, Africell)</li>
                                <li><i class="bi bi-check-circle-fill"></i> Tableau de bord inclus</li>
                                <li><i class="bi bi-check-circle-fill"></i> Envoi de groupe & personnalisation</li>
                                <li><i class="bi bi-check-circle-fill"></i> Importation de contacts (Excel)</li>
                                <li><i class="bi bi-check-circle-fill"></i> Support prioritaire 24/7</li>
                            </ul>
                            <a href="{{ path("app_confirmer_commande", {prix:0.06, montant:150}) }}" class="buy-btn">Commander</a>
                        </div>
                    </div>

                </div>

                <!-- Pack personnalisé -->
                <div class="custom-pack-section" data-aos="fade-up" data-aos-delay="200">
                    <i class="bi bi-sliders2 custom-pack-icon"></i>
                    <h3>Besoin d'un volume sur mesure ?</h3>
                    <p>Vous avez un projet spécifique ou un budget différent ? Configurez votre propre pack SMS personnalisé selon vos besoins.</p>
                    <a href="{{ path("app_commande") }}" class="btn-custom">Configurer mon pack <i class="bi bi-arrow-right ms-2"></i></a>
                </div>

            </div>

        </section><!-- /Pricing Section -->

        <!-- Contact Section -->
        <section id="contact" class="contact section light-background">

            <div class="container section-title" data-aos="fade-up">
                <span>Contact</span>
                <h2>Contactez-nous</h2>
                <p>Une question ? Notre équipe vous répond dans les plus brefs délais.</p>
            </div>

            <div class="container" data-aos="fade-up" data-aos-delay="100">

                <div class="row gy-4 mb-4">

                    <div class="col-lg-4 col-md-4" data-aos="fade-up" data-aos-delay="200">
                        <div class="info-item d-flex flex-column justify-content-center align-items-center">
                            <i class="bi bi-geo-alt-fill"></i>
                            <h3>Adresse</h3>
                            <p>1434 RN39, Kolwezi, Lualaba / RDC</p>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-4" data-aos="fade-up" data-aos-delay="300">
                        <div class="info-item d-flex flex-column justify-content-center align-items-center">
                            <i class="bi bi-whatsapp"></i>
                            <h3>Appel & WhatsApp</h3>
                            <p><a href="https://wa.me/+243851331051">+243 851 331 051</a></p>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-4" data-aos="fade-up" data-aos-delay="400">
                        <div class="info-item d-flex flex-column justify-content-center align-items-center">
                            <i class="bi bi-envelope-fill"></i>
                            <h3>Email</h3>
                            <p><a href="mailto:info@msg-pro.com">info@msg-pro.com</a></p>
                        </div>
                    </div>

                </div>

                <div class="row gy-4 mt-1">
                    <div class="col-lg-6" data-aos="fade-up" data-aos-delay="300">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d63706.98!2d25.4667!3d-10.7167!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x19f27b4e0a0a0a0b%3A0x0!2sKolwezi%2C+Lualaba%2C+RDC!5e0!3m2!1sfr!2scd!4v1712000000000" frameborder="0" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                    </div>

                    <div class="col-lg-6" data-aos="fade-up" data-aos-delay="400">
                        {% for message in app.flashes('success') %}
                            <div class="alert alert-success mb-3">{{ message }}</div>
                        {% endfor %}
                        {% for message in app.flashes('danger') %}
                            <div class="alert alert-danger mb-3">{{ message }}</div>
                        {% endfor %}

                        <form action="{{ path('app_landing_contact') }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('landing_contact') }}">
                            <div class="row gy-3">
                                <div class="col-md-6">
                                    <input type="text" name="name" class="form-control" placeholder="Votre Nom" required>
                                </div>
                                <div class="col-md-6">
                                    <input type="email" class="form-control" name="email" placeholder="Votre Email" required>
                                </div>
                                <div class="col-12">
                                    <input type="text" class="form-control" name="subject" placeholder="Sujet" required>
                                </div>
                                <div class="col-12">
                                    <textarea class="form-control" name="message" rows="6" placeholder="Votre message..." required></textarea>
                                </div>
                                <div class="col-12">
                                    <button type="submit">Envoyer le message <i class="bi bi-send ms-2"></i></button>
                                </div>
                            </div>
                        </form>
