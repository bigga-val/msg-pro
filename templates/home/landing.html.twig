    </main>

    <footer id="footer" class="footer position-relative dark-background">

        <div class="container footer-top">
            <div class="row gy-4">
                <div class="col-lg-4 col-md-6">
                    <div class="footer-about">
                        <a href="" class="logo sitename">MSG-PRO</a>
                        <div class="footer-contact pt-3">
                            <p>1434 RN39,</p>
                            <p>Kolwezi, Lualaba / RDC</p>
                            <p class="mt-3"><strong>Tél :</strong> <span>+243 851 331 051</span></p>
                            <p><strong>Email :</strong> <span>info@msg-pro.com</span></p>
