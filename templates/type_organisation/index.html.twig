{% extends 'base.html.twig' %}

{% block title %}Types d'Organisation{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-gradient-dark d-flex justify-content-between align-items-center">
                    <h3 class="card-title mb-0">Types d'Organisation</h3>
                    <a href="{{ path('app_type_organisation_new') }}" class="btn btn-success btn-sm">
                        <i class="fas fa-plus"></i> Nouveau type
                    </a>
                </div>
                <div class="card-body">
                    <table class="table table-striped table-hover datatable">
                        <thead class="thead-dark">
                        <tr>
                            <th>#</th>
                            <th>Désignation</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% set counter = 0 %}
                        {% for type_organisation in type_organisations %}
                            {% set counter = counter + 1 %}
                            <tr>
                                <td>{{ counter }}</td>
                                <td>{{ type_organisation.designation }}</td>
                                <td>
                                    <a href="{{ path('app_type_organisation_show', {'id': type_organisation.id}) }}" class="btn btn-sm btn-default">Détails</a>
                                    <a href="{{ path('app_type_organisation_edit', {'id': type_organisation.id}) }}" class="btn btn-sm btn-primary">Modifier</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="3" class="text-center text-muted">Aucun type trouvé</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
